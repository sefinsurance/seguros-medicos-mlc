---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const lang = 'en';
const waText = 'Hi, I have questions about health insurance in Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const faqs = [
  { q: 'Do you serve all of Florida?', a: 'Yes. We help clients statewide. WhatsApp is the fastest way to reach us.' },
  { q: 'What do I need to check ACA eligibility?', a: 'Your county, household size, and estimated household income. That’s enough to start.' },
  { q: 'Can I enroll outside Open Enrollment?', a: 'Sometimes. Losing coverage, moving, marriage, new baby and other life events can trigger Special Enrollment.' },
  { q: 'When should I start planning for Medicare?', a: 'In many cases, up to 3 months before your 65th birthday month.' },
  { q: 'What if I lost Medicaid?', a: 'There may be a Special Enrollment opportunity. The key is avoiding a coverage gap.' },
  { q: 'Does it cost to get guidance?', a: 'Message us and we’ll guide you. If you qualify for assistance or subsidies, we explain it clearly.' },
];
---
<SiteShell
  lang={lang}
  title="Frequently Asked Questions | Seguros Médicos"
  description="Clear answers about ACA, Medicare, Medicaid and coverage options in Florida."
  canonical="https://obamacarelocal.com/en/faq/"
>
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida statewide</span>
      <h1>Frequently Asked Questions</h1>
      <p>
        Here are quick answers. If your situation is specific (and most are),
        message us and we’ll review it with you personally.
      </p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref} rel="noopener">Message us on WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Call 1-877-458-2557</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card">
        <h2>Quick Answers</h2>
        <FaqAccordion items={faqs} />
      </div>

      <div style="height:16px"></div>

      <div class="card" style="background:linear-gradient(180deg, rgba(27,126,166,.10), rgba(11,79,108,.04))">
        <h2>Prefer a real conversation?</h2>
        <p class="small">
          Message us on WhatsApp and describe your situation in one sentence.
          We’ll guide you from there.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px">
          <a class="btn btn-primary" href={waHref} rel="noopener">Open WhatsApp</a>
          <a class="btn btn-light" href="/en/">Back to home</a>
        </div>
      </div>
    </div>
  </section>
</SiteShell>