---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const lang = 'es';
const waText = 'Hola, quiero ayuda con Medicare en Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const bullets = [
  'Puedes prepararte hasta 3 meses antes de cumplir 65',
  'Comparamos Medicare Advantage vs Medicare Original (sin enredos)',
  'Revisamos si tus doctores y clínicas están en la red',
  'Chequeamos recetas para evitar sorpresas',
  'Opciones y beneficios cambian según tu condado en Florida',
];

const faqs = [
  { q: '¿De verdad puedo empezar 3 meses antes de cumplir 65?', a: 'Sí. Tu ventana inicial normalmente incluye 3 meses antes del mes de tu cumpleaños. Planificar temprano te da más control.' },
  { q: '¿Qué es Medicare Advantage?', a: 'Es un plan ofrecido por compañías privadas que reemplaza Medicare Original. Tiene red, reglas y beneficios específicos.' },
  { q: '¿Me ayudan a elegir sin presión?', a: 'Sí. Nuestra meta es que entiendas lo que estás comprando y por qué te conviene.' },
];
---
<SiteShell
  lang={lang}
  title="Medicare en Florida | Seguros Médicos"
  description="¿Cumples 65 pronto? Podemos ayudarte a preparar tu plan hasta 3 meses antes de tu cumpleaños."
  canonical="https://obamacarelocal.com/es/medicare/"
>
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida (Estado completo)</span>
      <h1>Medicare en Florida</h1>
      <p>¿Cumples 65 pronto? Podemos ayudarte a preparar tu plan hasta 3 meses antes de tu cumpleaños.</p>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref} rel="noopener">Escríbenos por WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Llamar 1-877-458-2557</a>
      </div>

      <p class="small" style="margin-top:12px;color:rgba(255,255,255,.88)">
        Si me dices tu fecha de nacimiento y condado, te digo rápido qué ventana aplica para ti.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card">
        <h2>Lo más común que revisamos contigo</h2>
        <ul class="list">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>

      <div style="height:16px"></div>

      <div class="card">
        <h2>Preguntas frecuentes</h2>
        <FaqAccordion items={faqs} />
      </div>

      <div style="height:16px"></div>

      <div class="card" style="background:linear-gradient(180deg, rgba(27,126,166,.10), rgba(11,79,108,.04))">
        <h2>¿Listo? Te lo explico en 2 minutos</h2>
        <p class="small">
          Escríbeme por WhatsApp y dime: fecha de nacimiento + condado + si ya tienes Parte A/B.
          Con eso te doy una guía clara de tus opciones.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px">
          <a class="btn btn-primary" href={waHref} rel="noopener">Abrir WhatsApp</a>
          <a class="btn btn-light" href="/es/">Volver al inicio</a>
        </div>
      </div>
    </div>
  </section>
</SiteShell>
