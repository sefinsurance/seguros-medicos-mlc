---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';

const lang = 'es';
const title = 'Perdí Medicaid: opciones de seguro médico';
const description = 'Si perdiste Medicaid, te ayudamos a revisar opciones (ACA/Marketplace, planes familiares y más). Atención en español.';

const faq_items = [
  { q: '¿Perder Medicaid me da un Período Especial?', a: 'Muchas veces sí. Si recibiste una carta de terminación o cambio, puedes calificar para inscribirte fuera de Open Enrollment. Escríbenos y lo confirmamos.' },
  { q: '¿Qué información necesitan?', a: 'Condado, edades, ingreso estimado del hogar y fecha en que termina Medicaid (si la tienes).' },
  { q: '¿Cómo evito sorpresas en impuestos?', a: 'Reportando cambios de ingreso durante el año. Te guiamos para hacerlo correctamente.' }
];

const crumbs = [
  { label: 'Inicio', href: '/es/' },
  { label: 'Perdí Medicaid' }
];

const canonical = 'https://obamacarelocal.com/es/losing-medicaid/';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://obamacarelocal.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Perdí Medicaid", "item": canonical }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      "mainEntity": faq_items.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<SiteShell lang={lang} title={title} description={description} canonical={canonical}>
  <main class="container">
    <Breadcrumbs items={crumbs} />

    <section class="hero">
      <h1>{title}</h1>
      <p class="lead">
        Si perdiste Medicaid o recibiste una carta, no estás solo. Te ayudamos a revisar si calificas para un Período Especial y a comparar planes del Marketplace (ACA) con créditos, para que el costo sea realista para tu hogar.
      </p>

      <div class="cta-row">
        <a class="btn primary" href={`https://wa.me/18774582557?text=${encodeURIComponent('Hola, perdí Medicaid y necesito opciones. ¿Me puedes orientar?')}`} target="_blank" rel="noopener noreferrer">
          Escribir por WhatsApp
        </a>
        <a class="btn" href="/es/aca">Ver ACA / Marketplace</a>
      </div>
    </section>

    <section class="card">
      <h2>Qué revisamos contigo</h2>
      <ul>
        <li>Fecha en que termina Medicaid (si aplica)</li>
        <li>Ingresos estimados del hogar</li>
        <li>Doctores, hospitales y medicamentos</li>
        <li>Mejor plan para tu presupuesto y necesidades</li>
      </ul>
    </section>

    <section class="card">
      <h2>Preguntas frecuentes</h2>
      <FaqAccordion items={faq_items} />
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</SiteShell>
