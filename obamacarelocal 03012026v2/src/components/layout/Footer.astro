---
const { lang } = Astro.props;

const waNumber = '18774582557';
const waText = lang === 'es'
  ? 'Hola, quiero ayuda con mi seguro médico (ACA/Marketplace o Medicare).'
  : 'Hi, I would like help with health insurance (ACA/Marketplace or Medicare).';

const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waText)}`;

const content = lang === 'es'
  ? {
      blurb: 'Seguro médico (ACA/Marketplace), Medicare, Vida y Dental en varios estados.',
      serve: 'Atendemos en: FL · TX · NC · SC · TN (y más).',
      hours: 'Lunes a Viernes · 9am–6pm (hora del Este)',
      cta: 'Escríbenos por WhatsApp',
      micro: 'Respuesta rápida · Atención en español · Comparación de planes',
      rights: 'Todos los derechos reservados.'
    }
  : {
      blurb: 'Health insurance (ACA/Marketplace), Medicare, Life & Dental across multiple states.',
      serve: 'Serving: FL · TX · NC · SC · TN (and more).',
      hours: 'Monday to Friday · 9am–6pm (ET)',
      cta: 'Message us on WhatsApp',
      micro: 'Fast response · Spanish support · Plan comparisons',
      rights: 'All rights reserved.'
    };
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-col">
      <div class="footer-brand">ObamacareLocal</div>
      <p class="footer-blurb">{content.blurb}</p>
      <p class="footer-blurb">{content.serve}</p>
      <p class="footer-micro">{content.micro}</p>
    </div>

    <div class="footer-col">
      <div class="footer-title">{lang === 'es' ? 'Contacto' : 'Contact'}</div>
      <a class="footer-link" href={waHref} target="_blank" rel="noopener noreferrer">{content.cta}</a>
      <div class="footer-small">WhatsApp: +1 (877) 458‑2557</div>
      <div class="footer-small">{content.hours}</div>
    </div>

    <div class="footer-col">
      <div class="footer-title">{lang === 'es' ? 'Enlaces' : 'Links'}</div>
      <a class="footer-link" href={`/${lang}/aca`}>{lang === 'es' ? 'Obamacare / ACA' : 'Obamacare / ACA'}</a>
      <a class="footer-link" href={`/${lang}/medicare`}>Medicare</a>
      <a class="footer-link" href={`/${lang}/compare`}>{lang === 'es' ? 'Comparar Planes' : 'Compare Plans'}</a>
      <a class="footer-link" href={`/${lang}/faq`}>FAQ</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div>© {new Date().getFullYear()} ObamacareLocal · {content.rights}</div>
  </div>
</footer>
