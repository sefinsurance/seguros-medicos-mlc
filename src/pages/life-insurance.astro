---
// Life Insurance service page — converted React→Astro. Content is static HTML;
// only Footer + quote modal hydrate.
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactBar from "@/components/home/ContactBar.astro";
import LifeInsuranceContent from "@/components/service/LifeInsuranceContent.jsx";
import Footer from "@/components/home/Footer.jsx";
import QuoteModalLauncher from "@/components/quote/QuoteModalLauncher.jsx";

const lang = "en";
---
<BaseLayout
  title="Life Insurance in Florida | MLC Insurance"
  description="Explore life insurance options for individuals and families in Florida. Simple, no-pressure bilingual guidance — call 877-458-2557 or message us on WhatsApp."
  canonical="https://obamacarelocal.com/life-insurance/">
  <div class="min-h-screen bg-gradient-to-b from-indigo-50 to-white">
    <ContactBar lang={lang} otherHref="/es/life/" />
    <div class="max-w-4xl mx-auto px-4 py-10">
      <LifeInsuranceContent lang={lang} />
      <div class="text-center mt-8">
        <button data-scroll-top class="text-[#1e3a5f] text-sm font-semibold hover:underline">↑ Back to top</button>
      </div>
    </div>
    <Footer client:visible lang={lang} />
    <QuoteModalLauncher client:idle lang={lang} />
  </div>
  <script is:inline>
    document.addEventListener("click", function (e) {
      if (e.target.closest("[data-open-quote]")) {
        e.preventDefault();
        window.dispatchEvent(new CustomEvent("mlc:open-quote", { detail: { source: "instant_quote" } }));
      } else if (e.target.closest("[data-scroll-top]")) {
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    });
  </script>
</BaseLayout>
