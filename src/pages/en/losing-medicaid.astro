---
import SiteShell from '../../components/layout/SiteShell.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';

const lang = 'en';
const siteUrl = 'https://obamacarelocal.com';
const canonical = `${siteUrl}/en/losing-medicaid/`;

const title = 'Lost Medicaid in Florida? Fast options (ACA / Marketplace)';
const description = 'If your Medicaid ended, you may qualify for a Special Enrollment Period to enroll in an ACA (Marketplace) plan and avoid a coverage gap. English & Spanish.';

const waText = 'Hi, I lost Medicaid and need health insurance options. Can you help me?';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/en/` },
        { "@type": "ListItem", "position": 2, "name": "Losing Medicaid", "item": canonical },
      ],
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": description,
      "inLanguage": "en",
      "isPartOf": { "@type": "WebSite", "@id": `${siteUrl}/#website`, "url": siteUrl, "name": "Seguros Médicos" },
    },
  ],
};

const breadcrumbItems = [
  { href: '/en/', label: 'Home' },
  { href: '/en/losing-medicaid', label: 'Losing Medicaid' },
];
---

<script type="application/ld+json">{JSON.stringify(jsonLd)}</script>

<SiteShell lang={lang} title={title} description={description} canonical={canonical}>
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida</span>
      <h1>Lost Medicaid? Don’t get stuck without coverage.</h1>
      <p>
        When Medicaid ends (or your “share of cost” changes), many people qualify for a <strong>Special Enrollment Period</strong>
        to enroll in an ACA (Marketplace) plan without waiting for Open Enrollment.
      </p>
      <Breadcrumbs items={breadcrumbItems} />
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref} rel="noopener">WhatsApp us</a>
        <a class="btn btn-outline" href="tel:+18774582557">Call 1-877-458-2557</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        <div class="card">
          <h2>What usually happens</h2>
          <p class="small">
            After Medicaid ends, there can be a short window to enroll in a Marketplace plan. If the deadline passes,
            you might be uninsured until the next enrollment period.
          </p>
        </div>

        <div class="card">
          <h2>What we need</h2>
          <ul class="list">
            <li>Dates: when did (or will) Medicaid end?</li>
            <li>Household size</li>
            <li>Estimated income (roughly)</li>
          </ul>
          <p class="small">With that, we’ll tell you the cleanest next step.</p>
        </div>

        <div class="card">
          <h2>English & Spanish</h2>
          <p class="small">
            We can help in English or Spanish. If you received a letter you don’t understand,
            send a photo through WhatsApp.
          </p>
        </div>
      </div>

      <div style="height:18px"></div>

      <div class="card" style="background:linear-gradient(180deg, rgba(27,126,166,.10), rgba(11,79,108,.04))">
        <h2>If you need to move fast, do it today.</h2>
        <p class="small">The sooner we confirm dates and options, the easier it is to avoid a coverage gap.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:12px">
          <a class="btn btn-primary" href={waHref} rel="noopener">Open WhatsApp</a>
          <a class="btn btn-light" href="/en/aca">See ACA (Marketplace)</a>
        </div>
      </div>
    </div>
  </section>
</SiteShell>
