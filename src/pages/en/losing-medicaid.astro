---
import SiteShell from '../../components/layout/SiteShell.astro';

const phone = '877-458-2557';
const digits = phone.replace(/[^0-9]/g,'');
const phoneHref = `tel:+1${digits}`;
---

<SiteShell
  lang="en"
  title="Losing Medicaid?"
  description="If you’re losing Medicaid, you may qualify for a Special Enrollment Period to get ACA / Marketplace coverage."
  canonical="https://obamacarelocal.com/en/losing-medicaid/"
>
  <section class="hero" style="padding:26px 0 14px">
    <div class="container">
      <span class="pill">SEP help · Fast guidance</span>
      <h1 style="margin:14px 0 10px">If you’re losing Medicaid, don’t wait.</h1>
      <p class="muted" style="max-width:70ch">
        Losing Medicaid can open a Special Enrollment Period (SEP) for Marketplace coverage.
        We’ll help you understand your timeline and compare all available plans.
      </p>
      <div style="margin-top:14px">
        <a class="btn btn-pill btn-gold" href={phoneHref}>Call / Text {phone}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid cols-2" style="align-items:start">
        <div class="card pad">
          <h2 style="margin-top:0;color:#0b1116">What to do now</h2>
          <ol class="muted" style="margin:10px 0 0;line-height:1.7">
            <li>Find your Medicaid termination notice (if you have it).</li>
            <li>Confirm the last day your Medicaid is active.</li>
            <li>Get a Marketplace quote and pick a start date to avoid gaps.</li>
          </ol>
        </div>
        <div class="card pad">
          <h2 style="margin-top:0;color:#0b1116">What we’ll need</h2>
          <ul class="muted" style="margin:10px 0 0;line-height:1.7">
            <li>ZIP code</li>
            <li>Household size</li>
            <li>Estimated yearly income</li>
            <li>Termination date / letter (if available)</li>
          </ul>
        </div>
      </div>

      <div class="card pad" style="margin-top:16px">
        <h2 style="margin-top:0;color:#0b1116">We shop all Marketplace plans</h2>
        <p class="muted">We’ll compare what’s available in your area and help you enroll with confidence.</p>
      </div>

      <div style="margin-top:16px;display:flex;gap:12px;flex-wrap:wrap">
        <a class="btn btn-pill btn-teal" href="/en/compare">Compare plans</a>
        <a class="btn btn-pill btn-gold" href={phoneHref}>Get help today</a>
      </div>
    </div>
  </section>

  <style>.section{padding:26px 0} h2{font-size:22px}</style>
</SiteShell>
