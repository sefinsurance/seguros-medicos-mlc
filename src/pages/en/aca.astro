---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const lang = 'en';
const waText = 'Hi, I want help comparing Obamacare (ACA) plans.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const title = 'Obamacare (ACA) Help';
const description = 'Compare Marketplace plans and check if you qualify for subsidies. Spanish & English help. No pressure.';

const who = [
  'No employer coverage (or it’s too expensive)',
  'Self‑employed / 1099',
  'Families who need coverage for children',
  'Recent income change or lost coverage',
];

const ask = [
  'ZIP code and county',
  'Household size',
  'Estimated annual income',
  'Preferred doctors/medications (if any)',
];

const sep = [
  'Lost Medicaid or job-based coverage',
  'Moved, got married, or had a baby',
  'A major income change',
];

const faqs = [
  { q: 'Do you charge to help?', a: 'No. We help you compare options and understand eligibility. If subsidies apply, we’ll explain how they work.' },
  { q: 'Can I enroll outside Open Enrollment?', a: 'Yes—if you qualify for a Special Enrollment Period (SEP), such as losing coverage, moving, marriage, birth, or a major income change.' },
  { q: 'Do you check doctors and prescriptions?', a: 'Yes. We help review networks and medications to avoid surprises.' },
  { q: 'Do you provide Spanish support?', a: 'Yes. We can help in English or Spanish—whatever is easier for you.' },
];
---

<SiteShell
  lang={lang}
  title={title}
  description={description}
  canonical="https://obamacarelocal.com/en/aca/"
>
  <section class="hero">
    <div class="container hero-inner">
      <div class="badge">Spanish & English • Family-first help</div>
      <h1>Obamacare (ACA) without the headache</h1>
      <p class="section-sub">
        We compare Marketplace plans and check whether you qualify for subsidies. Clear answers, no pressure—
        just help choosing what fits your family.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href="/en/compare/">Compare plans</a>
        <a class="btn btn-outline" href={waHref} rel="noopener">Quote on WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Call 877‑458‑2557</a>
      </div>

      <div class="grid grid-3" style="margin-top:18px">
        <div class="card">
          <h3>Fast & clear</h3>
          <p>In minutes you’ll know your options and what the real cost looks like.</p>
        </div>
        <div class="card">
          <h3>Networks checked</h3>
          <p>Doctors, clinics, prescriptions—so the plan works in real life.</p>
        </div>
        <div class="card">
          <h3>SEP guidance</h3>
          <p>Lost Medicaid or coverage? We guide you step by step.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="prose-container">
      <h2>In 2 minutes we can check eligibility</h2>
      <p class="muted section-sub">
        These are the most common questions. If you don’t have everything ready, that’s fine—we start with basics.
      </p>

      <div class="grid" style="margin-top:14px">
        <div class="card">
          <h2>Who should consider ACA?</h2>
          <ul class="list">
            {who.map((x) => <li>{x}</li>)}
          </ul>
        </div>

        <div class="card">
          <h2>What we’ll ask for</h2>
          <ul class="list">
            {ask.map((x) => <li>{x}</li>)}
          </ul>
        </div>

        <div class="card">
          <h2>Special Enrollment Period (SEP)</h2>
          <p class="muted">
            If you had a major life change, you may be able to enroll outside Open Enrollment.
          </p>
          <ul class="list">
            {sep.map((x) => <li>{x}</li>)}
          </ul>
          <p class="small" style="margin-top:10px">
            Not sure? Message us and we’ll confirm.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="prose-container">
      <h2>Why families choose us</h2>
      <p class="muted section-sub">
        No pressure sales. Our goal is simple: help you understand options and pick a plan that actually fits.
      </p>

      <div class="feature-grid" style="margin-top:14px">
        <div class="card tight">
          <h3>Plain-language help</h3>
          <p class="muted">Clear explanations and time for questions.</p>
        </div>
        <div class="card tight">
          <h3>Subsidies & real costs</h3>
          <p class="muted">We explain premiums, deductibles, max out-of-pocket, and income impact.</p>
        </div>
        <div class="card tight">
          <h3>Doctors & prescriptions</h3>
          <p class="muted">We help check networks and medications to avoid surprises.</p>
        </div>
      </div>

      <div class="cta-band" style="margin-top:18px">
        <h3 style="margin:0 0 8px">Ready to compare?</h3>
        <p>
          Text us on WhatsApp or call. If you already have a plan, we can review it and help you avoid surprises.
        </p>
        <div class="cta-row" style="margin-top:12px">
          <a class="btn btn-primary" href="/en/compare/">Compare plans</a>
          <a class="btn btn-outline" href={waHref} rel="noopener">WhatsApp</a>
          <a class="btn btn-outline" href="/en/faq/">FAQs</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="prose-container">
      <h2>Frequently asked questions</h2>
      <FaqAccordion items={faqs} />
      <p class="small" style="margin-top:14px">
        Note: We are not affiliated with the government. “Obamacare” refers to Marketplace plans under the ACA.
      </p>
    </div>
  </section>
</SiteShell>
