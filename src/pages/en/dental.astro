---
import SiteShell from '../../components/layout/SiteShell.astro';

const lang = 'en';
const waText = 'Hi, I would like dental insurance options in Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
---
<SiteShell
  lang={lang}
  title="Dental Insurance in Florida | Seguros Médicos"
  description="Affordable dental options for you and your family."
  canonical="https://obamacarelocal.com/en/dental/"
>
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida statewide</span>
      <h1>Dental Insurance in Florida</h1>
      <p>
        Cleanings, x-rays, major procedures.
        We help you compare dental options that actually fit your budget.
      </p>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref}>Message us on WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Call</a>
      </div>
    </div>
  </section>
</SiteShell>