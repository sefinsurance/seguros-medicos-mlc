---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const lang = 'en';
const waText = 'Hi, I would like help with health insurance in Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const faq_items = [
  { q: 'Do you serve all of Florida?', a: 'Yes—Florida statewide. WhatsApp is the fastest way to get help.' },
  { q: 'What do you need to guide me?', a: 'Name, date of birth, your Florida county, and an estimate of household income.' },
  { q: 'Does it cost to get help?', a: 'Message us and we’ll guide you. If you qualify for subsidies or special options, we explain it clearly.' },
];
---
<SiteShell
  lang={lang}
  title="Florida Health Insurance Help | ACA • Medicare • Life • Dental"
  description="Warm, professional guidance to choose coverage in Florida. WhatsApp-first."
  canonical="https://obamacarelocal.com/en/"
>
  <section class="hero">
    <div class="container hero-inner">
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px">
        <span class="badge">Florida statewide</span>
        <span class="badge">English & Spanish</span>
        <span class="badge">WhatsApp-first</span>
      </div>

      <h1>Ready to find coverage that actually fits your life?</h1>
      <p>
        In Florida, many people overpay or lose coverage simply because nobody explained the options clearly.
        We keep it simple and guide you step by step—like a real conversation.
      </p>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref} rel="noopener">Message us on WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Call 1-877-458-2557</a>
      </div>

      <p class="small" style="margin-top:12px;color:rgba(255,255,255,.88)">
        Tip: Turning 65 soon? We can help you prepare Medicare up to <strong>3 months before</strong> your birthday.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>What do you need help with today?</h2>
      <p class="small">Pick what matches your situation. If you’re not sure, message us and we’ll figure it out together.</p>

      <div class="grid grid-3" style="margin-top:14px">
        <a class="card" href="/en/aca">
          <h3>ACA (Marketplace)</h3>
          <p class="small">Under 65? Subsidies, Open Enrollment, and Special Enrollment options.</p>
        </a>

        <a class="card" href="/en/medicare">
          <h3>Medicare</h3>
          <p class="small">Turning 65 or already enrolled—get calm, clear help choosing the right path.</p>
        </a>

        <a class="card" href="/en/losing-medicaid">
          <h3>Losing Medicaid</h3>
          <p class="small">If Medicaid ended, there may be fast options to avoid a coverage gap.</p>
        </a>

        <a class="card" href="/en/life">
          <h3>Life Insurance</h3>
          <p class="small">Protect your family with options that are simple and affordable.</p>
        </a>

        <a class="card" href="/en/dental">
          <h3>Dental</h3>
          <p class="small">Dental coverage options you can actually compare.</p>
        </a>

        <a class="card" href="/en/compare">
          <h3>Compare Plans</h3>
          <p class="small">Not just price: doctors, prescriptions, deductibles, and max out-of-pocket.</p>
        </a>
      </div>
    </div>
  </section>

<section class="section">
  <div class="container">
    <h2>Counties by state</h2>
    <p class="small">
      Choose your state to browse counties and local coverage options. (Florida & Texas have wider coverage.)
    </p>

    <div class="grid grid-3" style="margin-top:14px">
      <a class="card" href="/en/florida/"><h3>Florida</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/texas/"><h3>Texas</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/north-carolina/"><h3>North Carolina</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/south-carolina/"><h3>South Carolina</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/georgia/"><h3>Georgia</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/arizona/"><h3>Arizona</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/tennessee/"><h3>Tennessee</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/ohio/"><h3>Ohio</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/indiana/"><h3>Indiana</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/michigan/"><h3>Michigan</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/missouri/"><h3>Missouri</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/mississippi/"><h3>Mississippi</h3><p class="small">Browse counties</p></a>
      <a class="card" href="/en/alabama/"><h3>Alabama</h3><p class="small">Browse counties</p></a>
    </div>
  </div>
</section>

  <section class="section">
    <div class="container">
      <div class="card" style="background:linear-gradient(180deg, rgba(27,126,166,.10), rgba(11,79,108,.04))">
        <h2>A quick chat can save you a lot</h2>
        <p class="small">
          Overpaying? Lost coverage? Not sure what you qualify for?
          Message us and we’ll guide you clearly so you can make a confident choice.
        </p>

        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px">
          <a class="btn btn-primary" href={waHref} rel="noopener">Open WhatsApp</a>
          <a class="btn btn-light" href="/en/faq">View FAQs</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Quick questions</h2>
      <FaqAccordion items={faq_items} />
    </div>
  </section>
</SiteShell>
