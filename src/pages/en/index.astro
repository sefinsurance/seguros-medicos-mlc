---
import SiteShell from '../../components/layout/SiteShell.astro';

const phone = '877-458-2557';
const digits = phone.replace(/[^0-9]/g,'');
const phoneHref = `tel:+1${digits}`;
const waHref = `https://wa.me/1${digits}`;
---

<SiteShell
  lang="en"
  title="Marketplace health insurance you can trust"
  description="MLC Insurance helps families compare all available ACA / Obamacare Marketplace plans. Call, text, or WhatsApp 877-458-2557."
  canonical="https://obamacarelocal.com/en/"
>
  <section class="hero">
    <div class="container split">
      <div>
        <span class="pill">Bilingual · Family-first · Marketplace experts</span>
        <h1>Find the right <span style="color:var(--accent)">Obamacare (ACA)</span> plan—without the headache.</h1>
        <p class="muted" style="max-width:60ch">
          MLC Insurance helps you compare <b>all available Marketplace plans</b> and enroll with confidence.
          We keep it simple, explain your options, and support you after enrollment.
        </p>

        <div class="actions" style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px">
          <a class="btn btn-pill btn-gold" href={phoneHref}>Call / Text {phone}</a>
          <a class="btn btn-pill btn-outline" href={waHref} rel="noopener">WhatsApp</a>
          <a class="btn btn-pill btn-outline" href="/en/compare">Compare options</a>
        </div>

        <div class="statrow">
          <div class="stat"><b>All Marketplace plans</b><span>We shop what’s available in your area</span></div>
          <div class="stat"><b>Fast quotes</b><span>Most people get answers in minutes</span></div>
          <div class="stat"><b>Real humans</b><span>English & Spanish support</span></div>
        </div>
      </div>

      <div class="card pad" style="background:#fff">
        <div class="kicker" style="color:var(--brand2)">What we help with</div>
        <h2 style="margin:10px 0 0;color:#0b1116">A plan that fits your family</h2>
        <p class="muted" style="margin:10px 0 0;color:rgba(15,23,42,.72)">
          Subsidies, deductibles, networks, prescriptions—we break it down and help you pick a plan that matches your needs.
        </p>
        <div class="grid" style="margin-top:14px">
          <div class="icon-card">
            <div class="icon">$</div>
            <div>
              <b style="color:#0b1116">Premium & subsidy guidance</b>
              <p>Understand tax credits and what changes can affect them.</p>
            </div>
          </div>
          <div class="icon-card">
            <div class="icon">🏥</div>
            <div>
              <b style="color:#0b1116">Doctor & hospital networks</b>
              <p>We help you avoid surprises by checking networks when possible.</p>
            </div>
          </div>
          <div class="icon-card">
            <div class="icon">🧾</div>
            <div>
              <b style="color:#0b1116">SEP & life changes</b>
              <p>Lost coverage, moved, had a baby, income changed—we’ll guide the next steps.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="kicker">Why families choose MLC</div>
      <h2>Warm, clear guidance—no pressure.</h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-top:14px">
        <div class="card pad">
          <b>Strong Hispanic family tone</b>
          <p class="muted">We meet you where you are—respectful, patient, and easy to understand.</p>
        </div>
        <div class="card pad">
          <b>We explain the “why”</b>
          <p class="muted">Not just a quote—real clarity on deductibles, copays, and coverage.</p>
        </div>
        <div class="card pad">
          <b>Support after enrollment</b>
          <p class="muted">Need to update income, add a dependent, or change plans later? We help.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:rgba(255,255,255,.04)">
    <div class="container">
      <div class="kicker">How it works</div>
      <h2>3 steps. Done.</h2>
      <div class="grid cols-3" style="margin-top:14px">
        <div class="card pad">
          <b>1) Tell us your basics</b>
          <p class="muted">Household size, ZIP code, and estimated income.</p>
        </div>
        <div class="card pad">
          <b>2) We compare options</b>
          <p class="muted">We review all available Marketplace plans and highlight your best fits.</p>
        </div>
        <div class="card pad">
          <b>3) Enroll & relax</b>
          <p class="muted">We help you enroll and keep your info updated when life changes.</p>
        </div>
      </div>
      <div style="margin-top:16px;display:flex;gap:12px;flex-wrap:wrap">
        <a class="btn btn-pill btn-gold" href={phoneHref}>Call / Text {phone}</a>
        <a class="btn btn-pill btn-teal" href="/en/aca">Learn about ACA</a>
        <a class="btn btn-pill btn-light" href="/en/faq">Common questions</a>
      </div>
    </div>
  </section>
</SiteShell>

<style>
  .hero{padding:46px 0 24px;background:radial-gradient(1200px 600px at 10% -10%, rgba(244,196,48,.28), transparent 60%),
    radial-gradient(900px 500px at 90% 10%, rgba(27,126,166,.32), transparent 55%),
    linear-gradient(180deg, rgba(255,255,255,.06), transparent 60%);
  }
  h1{font-size:clamp(34px,5vw,54px);line-height:1.05;margin:14px 0 12px}
  h2{font-size:clamp(24px,3vw,34px);margin:10px 0}
  .section{padding:34px 0}
</style>
