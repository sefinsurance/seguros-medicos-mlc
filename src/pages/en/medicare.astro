---
import SiteShell from '../../components/layout/SiteShell.astro';

const phone = '877-458-2557';
const digits = phone.replace(/[^0-9]/g,'');
const phoneHref = `tel:+1${digits}`;
---

<SiteShell
  lang="en"
  title="Medicare Guidance"
  description="Medicare questions? MLC Insurance can help explain options and next steps."
  canonical="https://obamacarelocal.com/en/medicare/"
>
  <section class="hero" style="padding:26px 0 14px">
    <div class="container">
      <span class="pill">Friendly guidance · Bilingual</span>
      <h1 style="margin:14px 0 10px">Medicare support (when you need it)</h1>
      <p class="muted" style="max-width:70ch">
        Turning 65, helping a parent, or reviewing coverage? We can explain the basics and help you understand what options are available in your area.
      </p>
      <div style="margin-top:14px">
        <a class="btn btn-pill btn-gold" href={phoneHref}>Call / Text {phone}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid cols-2" style="align-items:start">
        <div class="card pad">
          <h2 style="margin-top:0;color:#0b1116">We can help you with</h2>
          <ul class="muted" style="margin:10px 0 0;line-height:1.7">
            <li>Understanding Part A & Part B</li>
            <li>When you can enroll (IEP, AEP, SEP, etc.)</li>
            <li>Reviewing current coverage and next steps</li>
          </ul>
        </div>
        <div class="card pad">
          <h2 style="margin-top:0;color:#0b1116">What to have ready</h2>
          <ul class="muted" style="margin:10px 0 0;line-height:1.7">
            <li>Date of birth</li>
            <li>Medicare number (if you have it)</li>
            <li>Current plan info (if enrolled)</li>
          </ul>
        </div>
      </div>

      <div class="card pad" style="margin-top:16px">
        <h2 style="margin-top:0;color:#0b1116">Also shopping Marketplace plans?</h2>
        <p class="muted">If you’re not eligible for Medicare yet, our team can help you compare ACA / Marketplace plans too.</p>
        <div style="margin-top:12px;display:flex;gap:12px;flex-wrap:wrap">
          <a class="btn btn-pill btn-teal" href="/en/aca">ACA / Obamacare</a>
          <a class="btn btn-pill btn-light" href="/en/compare">Compare plans</a>
        </div>
      </div>

      <p class="muted" style="margin-top:14px;font-size:13px">
        Disclaimer: Medicare plan availability varies by area and eligibility.
      </p>
    </div>
  </section>

  <style>
    .section{padding:26px 0}
    h2{font-size:22px}
  </style>
</SiteShell>
