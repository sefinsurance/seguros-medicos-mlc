---
// Medicare Advantage service page — converted React→Astro. The page chrome is
// Astro/islands; the content stays a hydrated island (client:visible) because it
// contains the interactive MedicareFAQ accordion.
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactBar from "@/components/home/ContactBar.astro";
import MedicareAdvantageContent from "@/components/service/MedicareAdvantageContent.jsx";
import Footer from "@/components/home/Footer.jsx";
import QuoteModalLauncher from "@/components/quote/QuoteModalLauncher.jsx";

const lang = "en";
---
<BaseLayout
  title="Medicare Advantage Plans in Florida | MLC Insurance"
  description="Compare Medicare Advantage plans in Florida with a licensed bilingual team. Free guidance on enrollment windows and coverage — call 877-458-2557 or message on WhatsApp."
  canonical="https://obamacarelocal.com/medicare-advantage/">
  <div class="min-h-screen" style="background:#e8f1f8">
    <ContactBar lang={lang} otherHref="/es/medicare/" />
    <div class="max-w-4xl mx-auto px-4 py-10">
      <MedicareAdvantageContent client:visible lang={lang} />
      <div class="text-center mt-8">
        <button data-scroll-top class="text-[#1e3a5f] text-sm font-semibold hover:underline">↑ Back to top</button>
      </div>
    </div>
    <Footer client:visible lang={lang} />
    <QuoteModalLauncher client:idle lang={lang} />
  </div>
  <script is:inline>
    document.addEventListener("click", function (e) {
      if (e.target.closest("[data-open-quote]")) {
        e.preventDefault();
        window.dispatchEvent(new CustomEvent("mlc:open-quote", { detail: { source: "instant_quote" } }));
      } else if (e.target.closest("[data-scroll-top]")) {
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    });
  </script>
</BaseLayout>
