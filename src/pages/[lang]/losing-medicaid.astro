---
import PageShell from "../../components/layout/PageShell.astro";
import Faq from "../../components/ui/Faq.astro";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang ?? "en";
const isEn = lang === "en";
const home = isEn ? (await import("../../i18n/en/home")).home : (await import("../../i18n/es/home")).home;
const mod = isEn ? await import("../../i18n/en/losing-medicaid") : await import("../../i18n/es/losing-medicaid");
const page = mod.losingMedicaid ?? mod["losing-medicaid"] ?? mod.default ?? {};
const kicker = page.kicker ?? page.hero?.eyebrow ?? (isEn ? "Coverage" : "Cobertura");
const title = page.title ?? page.hero?.title ?? (isEn ? "Lost Medicaid?" : "¿Perdiste Medicaid?");
const desc = page.desc ?? page.hero?.body ?? "";
const points = Array.isArray(page.points) ? page.points : Array.isArray(page.bullets) ? page.bullets : [];
const faqItems = Array.isArray(page.faq) ? page.faq : Array.isArray(page.faqs) ? page.faqs : [];
const waText = isEn ? "Hi, I lost Medicaid and need help with next steps." : "Hola, perdí Medicaid y necesito ayuda con los próximos pasos.";
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
const cards = isEn
  ? [
      { title: "Timing matters", body: "When Medicaid ends, your enrollment window may be time-sensitive. Acting quickly helps avoid a gap." },
      { title: "SEP review", body: "In many cases, losing Medicaid can open a Special Enrollment Period for other coverage." },
      { title: "Simple next steps", body: "We help confirm dates, documents, and what type of coverage makes the most sense next." },
    ]
  : [
      { title: "El tiempo importa", body: "Cuando termina Medicaid, la ventana para inscribirte puede ser sensible a fechas. Actuar rápido ayuda a evitar un vacío." },
      { title: "Revisión de SEP", body: "En muchos casos, perder Medicaid abre un Periodo Especial para otra cobertura." },
      { title: "Próximos pasos claros", body: "Confirmamos fechas, documentos y qué tipo de cobertura tiene más sentido ahora." },
    ];
const checklist = isEn
  ? ["End date from your letter or portal", "Reason coverage ended", "Household and income details", "Any current doctors or medications"]
  : ["Fecha final en la carta o portal", "Razón por la que terminó la cobertura", "Datos del hogar e ingreso", "Doctores o medicinas actuales"];
const links = [
  { href: `/${lang}/aca`, label: "ACA" },
  { href: `/${lang}/compare`, label: isEn ? "Compare plans" : "Comparar planes" },
  { href: `/${lang}/faq`, label: isEn ? "FAQs" : "Preguntas" },
];
---

<PageShell lang={lang} t={home} kicker={kicker} title={title} desc={desc} ctaHref={waHref} ctaText={isEn ? "Get help on WhatsApp" : "Recibir ayuda por WhatsApp"} secondaryHref={`/${lang}/aca`} secondaryText={isEn ? "See ACA options" : "Ver opciones ACA"} links={links}>
  <div class="feature-grid feature-grid-3">
    {cards.map((card) => (
      <div class="page-surface tight-card">
        <h3>{card.title}</h3>
        <p class="muted">{card.body}</p>
      </div>
    ))}
  </div>

  <div class="split-grid">
    <div class="page-surface">
      <h2 class="title">{isEn ? "Recommended steps" : "Pasos recomendados"}</h2>
      <ul class="content-list">
        {points.map((p)=>(<li>{p}</li>))}
      </ul>
    </div>

    <div class="page-surface">
      <h2 class="title">{isEn ? "What helps us review your case fast" : "Lo que ayuda a revisar tu caso rápido"}</h2>
      <ul class="content-list compact-list">
        {checklist.map((item)=>(<li>{item}</li>))}
      </ul>
      <p class="muted">{isEn ? "Those basics help us confirm timing and the next best coverage path." : "Eso nos ayuda a confirmar fechas y el mejor siguiente camino de cobertura."}</p>
    </div>
  </div>

  <div class="page-surface">
    <h2 class="title">{isEn ? "Frequently asked questions" : "Preguntas frecuentes"}</h2>
    <Faq items={faqItems} />
  </div>
</PageShell>
