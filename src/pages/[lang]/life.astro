---
import PageShell from "../../components/layout/PageShell.astro";
import Faq from "../../components/ui/Faq.astro";

export async function getStaticPaths(){ return [{ params: { lang: "es" } }, { params: { lang: "en" } }]; }

const lang = Astro.params.lang ?? "en";
const isEn = lang === "en";
const home = isEn ? (await import("../../i18n/en/home")).home : (await import("../../i18n/es/home")).home;
const page = isEn ? (await import("../../i18n/en/life")).life : (await import("../../i18n/es/life")).life;

const kicker = page?.kicker ?? page?.hero?.eyebrow ?? (isEn ? "Life" : "Vida");
const title = page?.title ?? page?.hero?.title ?? (isEn ? "Life insurance" : "Seguro de vida");
const desc = page?.desc ?? page?.hero?.body ?? "";
const points = Array.isArray(page?.points) ? page.points : Array.isArray(page?.bullets) ? page.bullets : [];
const faqItems = Array.isArray(page?.faq) ? page.faq : Array.isArray(page?.faqs) ? page.faqs : [];
const waText = isEn ? "Hi, I want help with life insurance." : "Hola, quiero ayuda con seguro de vida.";
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
const cards = isEn
  ? [
      { title: "Protect income", body: "Coverage can help replace lost income and keep key bills manageable for your family." },
      { title: "Flexible budgets", body: "We help compare options around what you actually want to spend each month." },
      { title: "Simple explanation", body: "Term, permanent, exam vs no-exam — we keep the tradeoffs clear and practical." },
    ]
  : [
      { title: "Protege el ingreso", body: "La cobertura puede ayudar a reemplazar ingresos y mantener manejables los gastos del hogar." },
      { title: "Presupuestos flexibles", body: "Comparamos opciones según lo que realmente quieres gastar al mes." },
      { title: "Explicación simple", body: "Término, permanente, con examen o sin examen — te explicamos las diferencias sin enredos." },
    ];
const checklist = isEn
  ? ["Age of the person applying", "Desired monthly budget", "Who depends on the coverage", "Any preference for term or permanent"]
  : ["Edad de la persona que aplica", "Presupuesto mensual deseado", "Quién depende de la cobertura", "Preferencia entre término o permanente"];
const links = [
  { href: `/${lang}/dental`, label: isEn ? "Dental" : "Dental" },
  { href: `/${lang}/compare`, label: isEn ? "Compare plans" : "Comparar planes" },
  { href: `/${lang}/faq`, label: isEn ? "FAQs" : "Preguntas" },
];
---

<PageShell lang={lang} t={home} kicker={kicker} title={title} desc={desc} ctaHref={waHref} ctaText={isEn ? "Chat on WhatsApp" : "Hablar por WhatsApp"} secondaryHref={`/${lang}/faq`} secondaryText={isEn ? "Common questions" : "Preguntas comunes"} links={links}>
  <div class="feature-grid feature-grid-3">
    {cards.map((card) => (
      <div class="page-surface tight-card">
        <h3>{card.title}</h3>
        <p class="muted">{card.body}</p>
      </div>
    ))}
  </div>

  <div class="split-grid">
    <div class="page-surface">
      <h2 class="title">{isEn ? "Why people consider life insurance" : "Por qué muchas personas consideran seguro de vida"}</h2>
      <ul class="content-list">
        {points.map((p)=>(<li>{p}</li>))}
      </ul>
    </div>

    <div class="page-surface">
      <h2 class="title">{isEn ? "Good starting info" : "Información útil para empezar"}</h2>
      <ul class="content-list compact-list">
        {checklist.map((item)=>(<li>{item}</li>))}
      </ul>
      <p class="muted">{isEn ? "That helps us recommend a realistic coverage range and type." : "Eso nos ayuda a recomendar un rango de cobertura y tipo más realista."}</p>
    </div>
  </div>

  <div class="page-surface">
    <h2 class="title">{isEn ? "Frequently asked questions" : "Preguntas frecuentes"}</h2>
    <Faq items={faqItems} />
  </div>
</PageShell>
