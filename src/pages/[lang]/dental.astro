---
import SiteShell from "../../components/layout/SiteShell.astro";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;

const copy = lang === "es"
  ? {
      badge: "Florida (Estado completo)",
      title: "Seguro Dental en Florida",
      desc: "Opciones dentales accesibles para ti y tu familia.",
      lead:
        "Limpiezas, radiografías y tratamientos. Podemos ayudarte a encontrar una opción dental que tenga sentido para tu presupuesto y tus necesidades.",
      wa: "Escríbenos por WhatsApp",
      call: "Llamar 877-458-2557",
      waText: "Hola, quiero opciones de seguro dental en Florida.",
      h2: "Cómo te ayudamos",
      bullets: [
        "Comparamos planes dentales individuales y familiares.",
        "Revisamos si prefieres cobertura preventiva, básica o mayor.",
        "Te explicamos costos mensuales, deducibles y periodos de espera.",
      ],
    }
  : {
      badge: "Florida statewide",
      title: "Dental Insurance in Florida",
      desc: "Affordable dental options for you and your family.",
      lead:
        "Cleanings, x-rays, and major procedures. We help you compare dental options that actually fit your budget and priorities.",
      wa: "Message us on WhatsApp",
      call: "Call 877-458-2557",
      waText: "Hi, I would like dental insurance options in Florida.",
      h2: "How we help",
      bullets: [
        "We compare individual and family dental plans.",
        "We review preventive, basic, and major coverage options.",
        "We explain premiums, deductibles, and waiting periods in plain language.",
      ],
    };

const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(copy.waText)}`;
const canonical = `https://obamacarelocal.com/${lang}/dental/`;
---

<SiteShell lang={lang} title={`${copy.title} | Seguros Médicos`} description={copy.desc} canonical={canonical}>
  <section class="hero-shell compact">
    <div class="container">
      <div class="hero-panel">
        <span class="hero-kicker">{copy.badge}</span>
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={waHref}>{copy.wa}</a>
          <a class="btn btn-outline" href="tel:+18774582557">{copy.call}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-stack">
        <div class="page-surface">
          <h2>{copy.h2}</h2>
          <ul class="content-list">
            {copy.bullets.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>
</SiteShell>
