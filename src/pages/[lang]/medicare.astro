---
import PageShell from "../../components/layout/PageShell.astro";
import Faq from "../../components/ui/Faq.astro";

export async function getStaticPaths(){ return [{ params: { lang: "es" } }, { params: { lang: "en" } }]; }

const lang = Astro.params.lang ?? "en";
const isEn = lang === "en";
const home = isEn ? (await import("../../i18n/en/home")).home : (await import("../../i18n/es/home")).home;
const page = isEn ? (await import("../../i18n/en/medicare")).medicare : (await import("../../i18n/es/medicare")).medicare;

const kicker = page?.kicker ?? page?.hero?.eyebrow ?? "Medicare";
const title = page?.title ?? page?.hero?.title ?? "Medicare";
const desc = page?.desc ?? page?.hero?.body ?? "";
const points = Array.isArray(page?.points) ? page.points : Array.isArray(page?.bullets) ? page.bullets : [];
const faqItems = Array.isArray(page?.faq) ? page.faq : Array.isArray(page?.faqs) ? page.faqs : [];
const waText = isEn ? "Hi, I want help with Medicare options." : "Hola, quiero ayuda con opciones de Medicare.";
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
const cards = isEn
  ? [
      { title: "Turning 65", body: "We help you time enrollment correctly so you can avoid gaps and possible late penalties." },
      { title: "Doctors & medications", body: "We compare around real usage: prescriptions, provider access, and plan fit." },
      { title: "Switching plans", body: "If your needs changed, we help review whether another option makes more sense." },
    ]
  : [
      { title: "Cumpliendo 65", body: "Te ayudamos a inscribirte en el momento correcto para evitar vacíos o posibles penalidades." },
      { title: "Doctores y medicinas", body: "Comparamos según uso real: recetas, acceso a proveedores y ajuste del plan." },
      { title: "Cambiar de plan", body: "Si tus necesidades cambiaron, revisamos si otra opción te conviene más." },
    ];
const checklist = isEn
  ? ["Date of birth", "Current Medicare parts or card info", "Prescription list", "Preferred doctors or clinics"]
  : ["Fecha de nacimiento", "Partes actuales de Medicare o datos de la tarjeta", "Lista de medicinas", "Doctores o clínicas preferidas"];
const links = [
  { href: `/${lang}/aca`, label: "ACA" },
  { href: `/${lang}/compare`, label: isEn ? "Compare plans" : "Comparar planes" },
  { href: `/${lang}/faq`, label: isEn ? "FAQs" : "Preguntas" },
];
---

<PageShell lang={lang} t={home} kicker={kicker} title={title} desc={desc} ctaHref={waHref} ctaText={isEn ? "Chat on WhatsApp" : "Hablar por WhatsApp"} secondaryHref={`/${lang}/compare`} secondaryText={isEn ? "Compare plans" : "Comparar planes"} links={links}>
  <div class="feature-grid feature-grid-3">
    {cards.map((card) => (
      <div class="page-surface tight-card">
        <h3>{card.title}</h3>
        <p class="muted">{card.body}</p>
      </div>
    ))}
  </div>

  <div class="split-grid">
    <div class="page-surface">
      <h2 class="title">{isEn ? "Common situations" : "Situaciones comunes"}</h2>
      <ul class="content-list">
        {points.map((p)=>(<li>{p}</li>))}
      </ul>
    </div>

    <div class="page-surface">
      <h2 class="title">{isEn ? "Useful before we compare" : "Útil antes de comparar"}</h2>
      <ul class="content-list compact-list">
        {checklist.map((item)=>(<li>{item}</li>))}
      </ul>
      <p class="muted">{isEn ? "That gives us enough to compare Medicare options in a practical way." : "Eso nos da lo suficiente para comparar Medicare de forma práctica."}</p>
    </div>
  </div>

  <div class="page-surface">
    <h2 class="title">{isEn ? "Frequently asked questions" : "Preguntas frecuentes"}</h2>
    <Faq items={faqItems} />
  </div>
</PageShell>
