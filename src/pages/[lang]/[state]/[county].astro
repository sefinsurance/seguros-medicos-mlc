---
import SiteShell from '../../../../components/layout/SiteShell.astro';
import FaqAccordion from '../../../../components/ui/FaqAccordion.astro';
import Breadcrumbs from '../../../../components/ui/Breadcrumbs.astro';
import { coverage } from '../../../../data/coverage';
import { countyCities } from '../../../../data/countyCities';

export async function getStaticPaths() {
  const langs = ['es', 'en'];
  const paths = [];

  for (const lang of langs) {
    for (const state of Object.keys(coverage)) {
      for (const county of coverage[state]) {
        paths.push({ params: { lang, state, county } });
      }
    }
  }

  return paths;
}

const { lang, state, county } = Astro.params;

const stateLabel = (state || '')
  .split('-')
  .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
  .join(' ');

const countyLabel = (county || '')
  .split('-')
  .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
  .join(' ');

const cities = countyCities?.[state]?.[county] || [];
const citiesLine = cities.length
  ? (lang === 'es'
      ? `Incluye áreas como ${cities.slice(0, 4).join(', ')}.`
      : `Includes areas like ${cities.slice(0, 4).join(', ')}.`)
  : '';

const title = lang === 'es'
  ? `Seguro médico en ${countyLabel} County, ${stateLabel}`
  : `Health insurance in ${countyLabel} County, ${stateLabel}`;

const description = lang === 'es'
  ? `Ayuda en español para comparar planes ACA/Marketplace, Medicare, Dental y Vida en ${countyLabel} County, ${stateLabel}. ${citiesLine} Cotiza rápido por WhatsApp.`
  : `Help comparing ACA/Marketplace, Medicare, Dental and Life plans in ${countyLabel} County, ${stateLabel}. ${citiesLine} Get options fast on WhatsApp.`;

const canonical = `https://obamacarelocal.com/${lang}/${state}/${county}/`;
const pageUrl = canonical;

const crumbs = [
  { label: lang === 'es' ? 'Inicio' : 'Home', href: `/${lang}/` },
  { label: stateLabel, href: `/${lang}/${state}/` },
  { label: countyLabel }
];

const waText = lang === 'es'
  ? `Hola, quiero ayuda con seguro médico en ${countyLabel} County, ${stateLabel}.`
  : `Hi, I want help with health insurance in ${countyLabel} County, ${stateLabel}.`;

const faq_items = lang === 'es'
  ? [
      { q: `¿Cuánto cuesta Obamacare (ACA) en ${countyLabel}?`, a: 'Depende del ingreso, edades y el plan. Te damos un estimado claro y comparamos 2–4 opciones buenas.' },
      { q: 'Perdí Medicaid, ¿qué hago ahora?', a: 'Si recibiste una carta de terminación o perdiste Medicaid, normalmente puedes calificar para un Período Especial. Te guiamos paso a paso.' },
      { q: '¿Atienden en español?', a: 'Sí. Te atendemos en español y revisamos doctores, medicamentos y beneficios para que el plan tenga sentido.' }
    ]
  : [
      { q: `How much does ACA cost in ${countyLabel}?`, a: 'It depends on income, ages, and plan choice. We give a clear estimate and compare 2–4 strong options.' },
      { q: 'I lost Medicaid—what now?', a: 'If you received a termination notice or lost Medicaid, you may qualify for a Special Enrollment Period. We’ll guide you step by step.' },
      { q: 'Do you help in Spanish?', a: 'Yes. We can assist in Spanish and review doctors, prescriptions, and benefits so the plan actually fits.' }
    ];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": (lang === "es" ? "Inicio" : "Home"), "item": `https://obamacarelocal.com/${lang}/` },
        { "@type": "ListItem", "position": 2, "name": stateLabel, "item": `https://obamacarelocal.com/${lang}/${state}/` },
        { "@type": "ListItem", "position": 3, "name": countyLabel, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": faq_items.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "ProfessionalService",
      "@id": `${pageUrl}#service`,
      "name": "ObamacareLocal",
      "url": pageUrl,
      "areaServed": [
        { "@type": "AdministrativeArea", "name": `${countyLabel} County, ${stateLabel}` }
      ],
      "availableLanguage": lang === "es" ? ["es", "en"] : ["en", "es"]
    }
  ]
};
---

<SiteShell lang={lang} title={title} description={description} canonical={canonical}>
  <main class="container">
    <Breadcrumbs items={crumbs} />

    <section class="hero">
      <h1>{title}</h1>
      <p class="lead">
        {lang === 'es'
          ? `Te ayudamos a elegir el plan correcto en ${countyLabel} County. Comparamos costo real, redes, medicamentos y beneficios. ${citiesLine}`
          : `We help you choose the right plan in ${countyLabel} County. We compare real cost, networks, prescriptions, and benefits. ${citiesLine}`}
      </p>

      <div class="cta-row">
        <a class="btn primary" href={`https://wa.me/18774582557?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer">
          {lang === 'es' ? 'Cotizar por WhatsApp' : 'Get a WhatsApp quote'}
        </a>
        <a class="btn" href={`/${lang}/${state}/`}>{lang === 'es' ? 'Ver mi estado' : 'Back to state'}</a>
      </div>
    </section>

    <section class="card">
      <h2>{lang === 'es' ? 'Lo que hacemos (rápido y claro)' : 'What we do (fast and clear)'}</h2>
      <ul>
        <li>{lang === 'es' ? 'ACA/Marketplace: opciones con créditos para bajar la prima.' : 'ACA/Marketplace: options with tax credits to reduce premiums.'}</li>
        <li>{lang === 'es' ? 'Revisamos doctores, hospitales y medicamentos antes de inscribirte.' : 'We check doctors, hospitals, and prescriptions before you enroll.'}</li>
        <li>{lang === 'es' ? 'Si perdiste Medicaid o cambiaste de trabajo, te decimos tu próxima mejor jugada.' : 'If you lost Medicaid or changed jobs, we guide your next best move.'}</li>
      </ul>

      <div style="margin-top:12px">
        <a class="btn" href={`/${lang}/losing-medicaid`}>{lang === 'es' ? 'Perdí Medicaid' : 'Lost Medicaid'}</a>
        <a class="btn" href={`/${lang}/compare`}>{lang === 'es' ? 'Comparar Planes' : 'Compare Plans'}</a>
      </div>
    </section>

    <section class="card">
      <h2>{lang === 'es' ? 'Preguntas frecuentes' : 'FAQ'}</h2>
      <FaqAccordion items={faq_items} />
    </section>

    <section class="card">
      <h2>{lang === 'es' ? 'Condados cercanos' : 'Nearby counties'}</h2>
      <p class="muted">
        {lang === 'es' ? 'Enlaces internos para ayudarte a navegar (y fortalecer SEO local).' : 'Internal links to help navigation (and strengthen local SEO).'}
      </p>
      <div class="grid counties">
        {(coverage[state] || []).filter((c) => c !== county).slice(0, 10).map((c) => (
          <a class="county-chip" href={`/${lang}/${state}/${c}/`}>{c.split('-').map((x)=>x.charAt(0).toUpperCase()+x.slice(1)).join(' ')}</a>
        ))}
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</SiteShell>
