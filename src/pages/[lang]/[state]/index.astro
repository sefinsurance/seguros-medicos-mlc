---
import SiteShell from '../../../components/layout/SiteShell.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import { coverage } from '../../../data/coverage';

export async function getStaticPaths() {
  const langs = ['es', 'en'];
  const states = Object.keys(coverage);

  return langs.flatMap((lang) =>
    states.map((state) => ({
      params: { lang, state },
    }))
  );
}

const { lang, state } = Astro.params;
const isES = lang === 'es';

function formatName(slug: string) {
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const siteUrl = 'https://obamacarelocal.com';
const stateName = formatName(state);
const counties = coverage[state] || [];

const waText = isES
  ? `Hola, quiero ayuda para comparar planes de Obamacare (ACA) en ${stateName}.`
  : `Hi, I want help comparing ACA (Marketplace) plans in ${stateName}.`;
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const title = isES
  ? `Seguros Médicos en ${stateName} | Condados`
  : `Health Insurance in ${stateName} | Counties`;

const description = isES
  ? `Explora condados en ${stateName}. Información sobre ACA (Obamacare), Medicare, pérdida de Medicaid y más.`
  : `Explore counties in ${stateName}. ACA (Marketplace), Medicare, losing Medicaid and more.`;

const canonical = `${siteUrl}/${lang}/${state}/`;
const pageUrl = canonical;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": isES ? "Inicio" : "Home",
          "item": `${siteUrl}/${lang}/`,
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": stateName,
          "item": pageUrl,
        },
      ],
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": title,
      "description": description,
      "inLanguage": isES ? "es" : "en",
      "isPartOf": {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        "url": siteUrl,
        "name": "Seguros Médicos",
      },
    },
  ],
};

const breadcrumbItems = [
  { href: `/${lang}/`, label: isES ? 'Inicio' : 'Home' },
  { href: `/${lang}/${state}/`, label: stateName },
];

const serviceLinks = [
  { href: `/${lang}/aca/`, label: isES ? 'Obamacare (ACA)' : 'ACA (Marketplace)' },
  { href: `/${lang}/medicare/`, label: 'Medicare' },
  { href: `/${lang}/dental/`, label: isES ? 'Dental' : 'Dental' },
  { href: `/${lang}/life/`, label: isES ? 'Vida' : 'Life' },
  { href: `/${lang}/losing-medicaid/`, label: isES ? 'Perdí Medicaid' : 'Losing Medicaid' },
];

const headline = isES ? `Seguro médico en ${stateName}` : `Health insurance in ${stateName}`;
const subhead = isES
  ? `Ayuda en español para comparar planes ACA/Marketplace, Medicare, Dental y Vida en ${stateName}. Selecciona tu condado para señales locales más fuertes en Google.`
  : `Compare ACA/Marketplace, Medicare, Dental and Life options in ${stateName}. Choose your county for stronger local signals in Google.`;
---

<script type="application/ld+json">{JSON.stringify(jsonLd)}</script>

<SiteShell lang={lang} title={title} description={description} canonical={canonical}>
  <section class="hero">
    <div class="container hero-inner">
      <div class="badge">{isES ? 'Se habla español • Atención familiar' : 'Bilingual help • Family-first'}</div>
      <h1>{headline}</h1>
      <p class="section-sub">{subhead}</p>

      <Breadcrumbs items={breadcrumbItems} />

      <div class="cta-row">
        <a class="btn btn-primary" href={`/${lang}/compare/`}>{isES ? 'Comparar planes' : 'Compare plans'}</a>
        <a class="btn btn-outline" href={waHref} rel="noopener">WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">{isES ? 'Llamar' : 'Call'} 877-458-2557</a>
      </div>

      <div class="grid grid-3" style="margin-top:18px">
        <div class="card">
          <h3>{isES ? 'Te explicamos claro' : 'Clear guidance'}</h3>
          <p>{isES ? 'Subsidios, costos reales, deducibles y máximos — sin presión.' : 'Subsidies, real costs, deductibles and max out-of-pocket — no pressure.'}</p>
        </div>
        <div class="card">
          <h3>{isES ? 'Revisamos redes' : 'We check networks'}</h3>
          <p>{isES ? 'Doctores, clínicas y medicinas para evitar sorpresas.' : 'Doctors, clinics and prescriptions to avoid surprises.'}</p>
        </div>
        <div class="card">
          <h3>{isES ? 'Ayuda con SEP' : 'Help with SEP'}</h3>
          <p>{isES ? 'Si perdiste Medicaid o empleo, te guiamos paso a paso.' : 'If you lost Medicaid or job coverage, we guide you step-by-step.'}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="prose-container">
      <h2>{isES ? 'Servicios que cubrimos' : 'Services we help with'}</h2>
      <p class="muted section-sub">
        {isES
          ? 'Elige un servicio o baja para seleccionar tu condado. Si no ves tu condado todavía, igual te ayudamos.'
          : `Pick a service or scroll to select your county. If you don't see your county yet, we can still help.`}
      </p>

      <div class="pill-links" style="margin-top:14px">
        {serviceLinks.map((s) => (
          <a href={s.href}>{s.label}</a>
        ))}
      </div>

      <div class="card" style="margin-top:18px">
        <h2 style="margin-bottom:8px">{isES ? 'Condados' : 'Counties'}</h2>
        <p class="small" style="margin-top:0">
          {isES
            ? 'Selecciona tu condado para señales locales más fuertes (y contenido más específico para tu área).'
            : 'Choose your county for stronger local signals (and more specific, local content).'}
        </p>

        <div class="pill-links" style="margin-top:14px">
          {counties.map((c) => (
            <a href={`/${lang}/${state}/${c}/`}>
              {isES ? `Condado de ${formatName(c)}` : `${formatName(c)} County`}
            </a>
          ))}
        </div>

        <p class="small" style="margin-top:14px">
          {isES
            ? '¿No ves tu condado? Escríbenos por WhatsApp con tu ZIP y te decimos la mejor opción.'
            : `Don't see your county? Message us your ZIP on WhatsApp and we'll help you anyway.`}
        </p>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="prose-container">
      <h2>{isES ? 'Ayuda rápida para familias hispanas' : 'Fast help for Hispanic families'}</h2>
      <p class="muted section-sub">
        {isES
          ? 'Optimizado para búsquedas en español: explicaciones claras y pasos prácticos.'
          : 'Built for bilingual search: clear explanations and practical steps.'}
      </p>

      <div class="feature-grid" style="margin-top:14px">
        <div class="card tight">
          <h3>{isES ? 'En español (de verdad)' : 'Spanish-first support'}</h3>
          <p class="muted">{isES ? 'Sin palabras raras. Te explicamos lo que sí importa.' : 'No jargon. We focus on what actually matters.'}</p>
        </div>
        <div class="card tight">
          <h3>{isES ? 'Costos reales' : 'Real costs'}</h3>
          <p class="muted">{isES ? 'Prima, deducible, máximo anual y subsidios según ingreso.' : 'Premium, deductible, annual max and income-based subsidies.'}</p>
        </div>
        <div class="card tight">
          <h3>{isES ? 'Doctores y medicinas' : 'Doctors & prescriptions'}</h3>
          <p class="muted">{isES ? 'Revisamos redes para que el plan funcione en tu vida.' : 'We check networks so the plan works in real life.'}</p>
        </div>
      </div>

      <div class="cta-band" style="margin-top:18px">
        <h3 style="margin:0 0 8px">{isES ? `¿Listo para comparar en ${stateName}?` : `Ready to compare in ${stateName}?`}</h3>
        <p>
          {isES
            ? 'Escríbenos por WhatsApp con tu ZIP y tamaño del hogar. Empezamos rápido.'
            : 'Message us your ZIP and household size on WhatsApp. We can start fast.'}
        </p>
        <div class="cta-row" style="margin-top:12px">
          <a class="btn btn-primary" href={`/${lang}/compare/`}>{isES ? 'Comparar planes' : 'Compare plans'}</a>
          <a class="btn btn-outline" href={waHref} rel="noopener">WhatsApp</a>
          <a class="btn btn-outline" href={`/${lang}/faq/`}>{isES ? 'Preguntas' : 'FAQs'}</a>
        </div>
      </div>
    </div>
  </section>
</SiteShell>
