---
import PageShell from "../../components/layout/PageShell.astro";
import Faq from "../../components/ui/Faq.astro";

export async function getStaticPaths(){ return [{ params: { lang: "es" } }, { params: { lang: "en" } }]; }

const lang = Astro.params.lang ?? "en";
const isEn = lang === "en";
const home = isEn ? (await import("../../i18n/en/home")).home : (await import("../../i18n/es/home")).home;
const page = isEn ? (await import("../../i18n/en/compare")).compare : (await import("../../i18n/es/compare")).compare;

const kicker = page?.kicker ?? page?.hero?.eyebrow ?? (isEn ? "Compare" : "Comparar");
const title = page?.title ?? page?.hero?.title ?? (isEn ? "Compare plans" : "Comparar planes");
const desc = page?.desc ?? page?.hero?.body ?? "";
const points = Array.isArray(page?.points) ? page.points : Array.isArray(page?.bullets) ? page.bullets : [];
const faqItems = Array.isArray(page?.faq) ? page.faq : Array.isArray(page?.faqs) ? page.faqs : [];
const waText = isEn ? "Hi, I want help comparing health plans." : "Hola, quiero ayuda comparando planes de salud.";
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
const cards = isEn
  ? [
      { title: "Beyond monthly premium", body: "We look at deductibles, copays, networks, and expected usage — not just the sticker price." },
      { title: "Doctor-focused", body: "A cheaper plan is not better if your doctors or medications do not fit well." },
      { title: "Clear side-by-side choices", body: "We help narrow options so the final decision feels simpler and more confident." },
    ]
  : [
      { title: "Más que la mensualidad", body: "Revisamos deducibles, copagos, redes y uso esperado — no solo el precio visible." },
      { title: "Enfocado en doctores", body: "Un plan más barato no siempre es mejor si no te funciona con doctores o medicinas." },
      { title: "Opciones claras lado a lado", body: "Te ayudamos a reducir opciones para que la decisión final sea más sencilla." },
    ];
const checklist = isEn
  ? ["ZIP code", "Household size or DOB", "Doctor and medication preferences", "Budget range or current premium"]
  : ["ZIP", "Tamaño del hogar o fecha de nacimiento", "Preferencia de doctores y medicinas", "Rango de presupuesto o prima actual"];
const links = [
  { href: `/${lang}/aca`, label: "ACA" },
  { href: `/${lang}/medicare`, label: "Medicare" },
  { href: `/${lang}/losing-medicaid`, label: isEn ? "Losing Medicaid" : "Perdí Medicaid" },
];
---

<PageShell lang={lang} t={home} kicker={kicker} title={title} desc={desc} ctaHref={waHref} ctaText={isEn ? "Start on WhatsApp" : "Empezar por WhatsApp"} secondaryHref={`/${lang}/aca`} secondaryText={isEn ? "See ACA help" : "Ver ayuda ACA"} links={links}>
  <div class="feature-grid feature-grid-3">
    {cards.map((card) => (
      <div class="page-surface tight-card">
        <h3>{card.title}</h3>
        <p class="muted">{card.body}</p>
      </div>
    ))}
  </div>

  <div class="split-grid">
    <div class="page-surface">
      <h2 class="title">{isEn ? "What we compare" : "Qué comparamos"}</h2>
      <ul class="content-list">
        {points.map((p)=>(<li>{p}</li>))}
      </ul>
    </div>

    <div class="page-surface">
      <h2 class="title">{isEn ? "What helps us narrow options" : "Lo que ayuda a reducir opciones"}</h2>
      <ul class="content-list compact-list">
        {checklist.map((item)=>(<li>{item}</li>))}
      </ul>
      <p class="muted">{isEn ? "That is usually enough for a practical first comparison." : "Eso normalmente es suficiente para una primera comparación práctica."}</p>
    </div>
  </div>

  <div class="page-surface">
    <h2 class="title">{isEn ? "Frequently asked questions" : "Preguntas frecuentes"}</h2>
    <Faq items={faqItems} />
  </div>
</PageShell>
