---
import PageShell from "../../components/layout/PageShell.astro";
import Faq from "../../components/ui/Faq.astro";

export async function getStaticPaths(){ return [{ params: { lang: "es" } }, { params: { lang: "en" } }]; }

const lang = Astro.params.lang ?? "en";
const isEn = lang === "en";
const home = isEn ? (await import("../../i18n/en/home")).home : (await import("../../i18n/es/home")).home;
const page = isEn ? (await import("../../i18n/en/aca")).aca : (await import("../../i18n/es/aca")).aca;

const kicker = page?.kicker ?? page?.hero?.eyebrow ?? (isEn ? "ACA" : "ACA");
const title = page?.title ?? page?.hero?.title ?? (isEn ? "ACA plans" : "Planes ACA");
const desc = page?.desc ?? page?.hero?.body ?? "";
const points = Array.isArray(page?.points) ? page.points : Array.isArray(page?.bullets) ? page.bullets : [];
const faqItems = Array.isArray(page?.faq) ? page.faq : Array.isArray(page?.faqs) ? page.faqs : [];
const waText = isEn ? "Hi, I want help with ACA health insurance." : "Hola, quiero ayuda con seguro médico ACA.";
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
const cards = isEn
  ? [
      { title: "Subsidy review", body: "We estimate whether you may qualify for premium help based on household and income." },
      { title: "Doctor & network check", body: "We compare options around your doctors, prescriptions, and total cost — not just the monthly premium." },
      { title: "SEP guidance", body: "Lost coverage, moved, got married, or had a baby? We help confirm whether you can enroll now." },
    ]
  : [
      { title: "Revisión de subsidio", body: "Estimamos si podrías calificar para ayuda con la prima según hogar e ingreso." },
      { title: "Doctores y red", body: "Comparamos planes según tus doctores, medicinas y costo total — no solo la mensualidad." },
      { title: "Ayuda con SEP", body: "Si perdiste cobertura, te mudaste, te casaste o tuviste un bebé, revisamos si puedes inscribirte ahora." },
    ];
const checklist = isEn
  ? ["ZIP code and county", "Household size", "Estimated annual income", "Current coverage or qualifying life event"]
  : ["ZIP y condado", "Tamaño del hogar", "Ingreso anual estimado", "Cobertura actual o evento de vida calificativo"];
const links = [
  { href: `/${lang}/medicare`, label: "Medicare" },
  { href: `/${lang}/compare`, label: isEn ? "Compare plans" : "Comparar planes" },
  { href: `/${lang}/losing-medicaid`, label: isEn ? "Losing Medicaid" : "Perdí Medicaid" },
];
---

<PageShell lang={lang} t={home} kicker={kicker} title={title} desc={desc} ctaHref={waHref} ctaText={isEn ? "Chat on WhatsApp" : "Hablar por WhatsApp"} secondaryHref={`/${lang}/compare`} secondaryText={isEn ? "Compare plans" : "Comparar planes"} links={links}>
  <div class="feature-grid feature-grid-3">
    {cards.map((card) => (
      <div class="page-surface tight-card">
        <h3>{card.title}</h3>
        <p class="muted">{card.body}</p>
      </div>
    ))}
  </div>

  <div class="split-grid">
    <div class="page-surface">
      <h2 class="title">{isEn ? "Common situations" : "Situaciones comunes"}</h2>
      <ul class="content-list">
        {points.map((p)=>(<li>{p}</li>))}
      </ul>
    </div>

    <div class="page-surface">
      <h2 class="title">{isEn ? "What we usually need" : "Lo que normalmente necesitamos"}</h2>
      <ul class="content-list compact-list">
        {checklist.map((item)=>(<li>{item}</li>))}
      </ul>
      <p class="muted">{isEn ? "With those basics, we can narrow down real ACA options fast." : "Con eso podemos aterrizar opciones ACA reales rápidamente."}</p>
    </div>
  </div>

  <div class="page-surface">
    <div class="surface-header-row">
      <div>
        <h2 class="title">{isEn ? "Frequently asked questions" : "Preguntas frecuentes"}</h2>
        <p class="muted">{isEn ? "Short answers first. Then we can review your exact case by phone or WhatsApp." : "Primero respuestas cortas. Luego revisamos tu caso exacto por llamada o WhatsApp."}</p>
      </div>
    </div>
    <Faq items={faqItems} />
  </div>
</PageShell>
