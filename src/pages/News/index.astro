---
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsTopBar from '@/components/news/NewsTopBar.jsx';
import Footer from '@/components/home/Footer.jsx';
import FormattedDate from '@/components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { NEWS_TITLE, NEWS_DESCRIPTION } from '@/consts';

// Surface published posts only. Sort newest first.
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title={NEWS_TITLE} description={NEWS_DESCRIPTION} canonical="https://obamacarelocal.com/News/">
  <NewsTopBar client:load />

  <main class="bg-slate-50 min-h-[60vh]">
    <section class="max-w-5xl mx-auto px-4 py-10">
      <header class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-[#1e3a5f]">News &amp; Updates</h1>
        <p class="mt-2 text-slate-600 max-w-2xl">
          Plain-language explainers on ACA Open Enrollment, Medicare changes, and other health-coverage news for Florida families.
        </p>
      </header>

      {posts.length === 0 ? (
        <div class="rounded-xl border border-slate-200 bg-white p-8 text-center text-slate-500">
          No articles published yet. Check back soon.
        </div>
      ) : (
        <ul class="grid gap-5 md:grid-cols-2" id="news-grid">
          {posts.map((post) => (
            <li
              class="bg-white rounded-xl border border-slate-200 hover:border-[#035582] hover:shadow-md transition-all overflow-hidden"
              data-slug={post.id}
              data-lang={post.data.language || 'en'}
              data-translation-slug={post.data.translationSlug || ''}
            >
              <a href={`/News/${post.id}/`} class="block p-5 h-full">
                {post.data.heroImage && (
                  <img src={post.data.heroImage} alt="" class="w-full h-44 object-cover rounded-lg mb-4" />
                )}
                <h2 class="text-lg font-semibold text-[#1e3a5f] leading-snug">{post.data.title}</h2>
                <p class="text-xs text-slate-500 mt-1">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && (
                  <p class="text-sm text-slate-600 mt-3 leading-relaxed line-clamp-3">{post.data.description}</p>
                )}
                <span class="inline-block mt-4 text-sm font-medium text-[#035582]">
                  {(post.data.language || 'en') === 'es' ? 'Leer más →' : 'Read more →'}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>

  <Footer client:load lang="en" />
</BaseLayout>

<script is:inline>
  // Language-aware filtering: hide the version of each post that doesn't
  // match the user's stored preference, but only when both versions exist
  // in this listing. Monolingual posts are always visible.
  (function () {
    try {
      var pref = localStorage.getItem("mlc_lang");
      if (pref !== "en" && pref !== "es") return;
      var grid = document.getElementById("news-grid");
      if (!grid) return;
      var cards = Array.from(grid.querySelectorAll("li[data-slug]"));
      var slugs = new Set(cards.map(function (c) { return c.getAttribute("data-slug"); }));
      cards.forEach(function (c) {
        var lang = c.getAttribute("data-lang");
        var pair = c.getAttribute("data-translation-slug");
        if (lang === pref) return;                  // matches preference — show
        if (!pair) return;                          // no translation — show as fallback
        if (slugs.has(pair)) c.style.display = "none"; // hide; the matching one is in the grid
      });
    } catch (e) {}
  })();
</script>
