---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const lang = 'es';
const waText = 'Hola, quiero ayuda con mi seguro médico en Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const title = 'Medicare en Florida';
const description = '¿Cumples 65 pronto? Podemos ayudarte a preparar tu plan hasta 3 meses antes de tu cumpleaños.';
const bullets = [
  'Ventana inicial (3 meses antes del cumpleaños)',
  'Medicare Advantage vs Original (explicado simple)',
  'Revisión de doctores y medicamentos',
  'Opciones según tu condado en Florida',
];
const faqs = [
  { q: '¿De verdad puedo empezar 3 meses antes?', a: 'Sí. Tu ventana inicial suele incluir 3 meses antes del mes de tu cumpleaños. Planificar temprano te evita estrés.' },
  { q: '¿Qué necesitan para orientarme?', a: 'Tu fecha de nacimiento, condado y si ya tienes Parte A/B. Si tomas medicinas, también ayuda.' },
  { q: '¿Me ayudan a comparar planes?', a: 'Sí. Comparamos red, beneficios y el costo real, no solo el precio mensual.' },
];
---
<SiteShell lang={lang} title={`${title} | Seguros Médicos`} description={description} canonical="https://obamacarelocal.com/es/medicare/">
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida (Estado completo)</span>
      <h1>{title}</h1>
      <p>{description}</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref} rel="noopener">Escríbenos por WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Llamar 1-877-458-2557</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card">
        <h2>Lo más común</h2>
        <ul class="list">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>

      <div style="height:16px"></div>

      <div class="card">
        <h2>Preguntas frecuentes</h2>
        <FaqAccordion items={faqs} />
      </div>

      <div style="height:16px"></div>

      <div class="card" style="background:linear-gradient(180deg, rgba(27,126,166,.10), rgba(11,79,108,.04))">
        <h2>¿Listo? Te lo hacemos fácil</h2>
        <p class="small">Escríbenos por WhatsApp y cuéntanos tu situación. Te orientamos con calma, como una conversación.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px">
          <a class="btn btn-primary" href={waHref} rel="noopener">Abrir WhatsApp</a>
          <a class="btn btn-light" href="/es/">Volver al inicio</a>
        </div>
      </div>
    </div>
  </section>
</SiteShell>
