---
import SiteShell from '../../components/layout/SiteShell.astro';

const lang = 'es';
const waText = 'Hola, quiero opciones de seguro dental en Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
---
<SiteShell
  lang={lang}
  title="Seguro Dental en Florida | Seguros Médicos"
  description="Opciones dentales accesibles para ti y tu familia."
  canonical="https://obamacarelocal.com/es/dental/"
>
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida (Estado completo)</span>
      <h1>Seguro Dental en Florida</h1>
      <p>
        Limpiezas, radiografías, tratamientos.
        Podemos ayudarte a encontrar una opción dental que tenga sentido para tu presupuesto.
      </p>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref}>Escríbenos por WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Llamar</a>
      </div>
    </div>
  </section>
</SiteShell>