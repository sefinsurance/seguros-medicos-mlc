---
import SiteShell from '../../components/layout/SiteShell.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';

const lang = 'es';
const siteUrl = 'https://obamacarelocal.com';
const canonical = `${siteUrl}/es/losing-medicaid/`;

const title = 'Perdiste Medicaid en Florida: opciones rápidas (ACA / Marketplace)';
const description = 'Si te cancelaron Medicaid, puede haber un Periodo Especial para inscribirte en Obamacare (ACA) y evitar quedarte sin cobertura. Hablamos español.';

const waText = 'Hola, perdí Medicaid y necesito opciones de seguro médico. ¿Me pueden ayudar?';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/es/` },
        { "@type": "ListItem", "position": 2, "name": "Perdiendo Medicaid", "item": canonical },
      ],
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": description,
      "inLanguage": "es",
      "isPartOf": { "@type": "WebSite", "@id": `${siteUrl}/#website`, "url": siteUrl, "name": "Seguros Médicos" },
    },
  ],
};

const breadcrumbItems = [
  { href: '/es/', label: 'Inicio' },
  { href: '/es/losing-medicaid', label: 'Perdiendo Medicaid' },
];
---

<script type="application/ld+json">{JSON.stringify(jsonLd)}</script>

<SiteShell lang={lang} title={title} description={description} canonical={canonical}>
  <section class="hero">
    <div class="container hero-inner">
      <span class="badge">Florida</span>
      <h1>¿Perdiste Medicaid? No te quedes sin cobertura.</h1>
      <p>
        Si te cancelaron Medicaid (o te subieron el “share of cost”), muchas personas califican para un <strong>Periodo Especial</strong>
        que permite inscribirte en Obamacare (ACA / Marketplace) sin esperar al Open Enrollment.
      </p>
      <Breadcrumbs items={breadcrumbItems} />
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
        <a class="btn btn-primary" href={waHref} rel="noopener">Escríbenos por WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Llamar 1-877-458-2557</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        <div class="card">
          <h2>Qué suele pasar</h2>
          <p class="small">
            Cuando termina Medicaid, puede haber una ventana corta para aplicar a un plan del Marketplace. Si se te pasa,
            podrías quedarte sin cobertura hasta la próxima inscripción.
          </p>
        </div>

        <div class="card">
          <h2>Qué necesitamos</h2>
          <ul class="list">
            <li>Fechas: ¿cuándo terminó (o termina) Medicaid?</li>
            <li>Personas en el hogar</li>
            <li>Ingreso estimado (aprox.)</li>
          </ul>
          <p class="small">Con eso te decimos si conviene ACA, otra opción, o qué paso sigue.</p>
        </div>

        <div class="card">
          <h2>Enfocado en la comunidad hispana</h2>
          <p class="small">
            Hablamos español y explicamos sin términos complicados. Si recibiste una carta que no entiendes,
            envíanos una foto por WhatsApp.
          </p>
        </div>
      </div>

      <div style="height:18px"></div>

      <div class="card" style="background:linear-gradient(180deg, rgba(27,126,166,.10), rgba(11,79,108,.04))">
        <h2>Si hoy mismo necesitas moverlo, mejor.</h2>
        <p class="small">
          Entre más rápido confirmemos fechas y opciones, más fácil evitar un “gap”.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:12px">
          <a class="btn btn-primary" href={waHref} rel="noopener">Abrir WhatsApp</a>
          <a class="btn btn-light" href="/es/aca">Ver Obamacare (ACA)</a>
        </div>
      </div>
    </div>
  </section>
</SiteShell>
