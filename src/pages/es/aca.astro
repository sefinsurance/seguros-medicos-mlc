---
import SiteShell from '../../components/layout/SiteShell.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const lang = 'es';
const waText = 'Hola, quiero ayuda para comparar planes de Obamacare (ACA).';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;

const title = 'Obamacare (ACA) en Español';
const description = 'Compara planes del Marketplace y revisa si calificas para subsidios. Ayuda en español, sin presión.';

const who = [
  'Sin seguro por empleo (o es muy caro)',
  'Trabajas por cuenta propia / 1099',
  'Familias que necesitan cubrir a los niños',
  'Cambio de ingreso o pérdida de cobertura',
];

const ask = [
  'Código ZIP y condado',
  'Tamaño del hogar (cuántos viven en casa)',
  'Ingreso anual estimado (lo más real posible)',
  'Doctores/medicinas preferidas (si aplica)',
];

const sep = [
  'Perdiste Medicaid o cobertura del trabajo',
  'Te mudaste, te casaste o tuviste un bebé',
  'Cambió tu ingreso de forma importante',
];

const faqs = [
  { q: '¿Cuánto cuesta hablar con un agente?', a: 'No cobramos por ayudarte a comparar opciones y entender tu elegibilidad. Si calificas para créditos (subsidios), te explicamos cómo funcionan.' },
  { q: '¿Necesito seguro social o estatus migratorio específico?', a: 'Depende del caso. Te guiamos con lo que aplica según tu situación y la documentación disponible.' },
  { q: '¿Puedo inscribirme fuera del periodo abierto?', a: 'Sí, si calificas para un Periodo Especial de Inscripción (SEP), por ejemplo por pérdida de cobertura, cambios de ingreso, mudanza, matrimonio o nacimiento.' },
  { q: '¿Me ayudan a verificar doctores y medicinas?', a: 'Sí. Revisamos redes, clínicas y medicamentos para evitar sorpresas.' },
];
---

<SiteShell
  lang={lang}
  title={title}
  description={description}
  canonical="https://obamacarelocal.com/es/aca/"
>
  <section class="hero">
    <div class="container hero-inner">
      <div class="badge">Se habla español • Atención familiar</div>
      <h1>Obamacare (ACA) sin estrés, en español</h1>
      <p class="section-sub">
        Comparamos planes del Marketplace y revisamos si calificas para subsidios. Te explicamos claro, sin presión,
        y te ayudamos a escoger lo mejor para tu familia.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href="/es/compare/">Comparar planes</a>
        <a class="btn btn-outline" href={waHref} rel="noopener">Cotizar por WhatsApp</a>
        <a class="btn btn-outline" href="tel:+18774582557">Llamar 877-458-2557</a>
      </div>

      <div class="grid grid-3" style="margin-top:18px">
        <div class="card">
          <h3>Rápido y claro</h3>
          <p>En minutos sabrás si hay opciones con crédito y qué plan conviene.</p>
        </div>
        <div class="card">
          <h3>Revisamos redes</h3>
          <p>Doctores, clínicas y medicinas — para evitar sorpresas.</p>
        </div>
        <div class="card">
          <h3>Ayuda con SEP</h3>
          <p>Perdiste Medicaid o empleo: te guiamos paso a paso.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="prose-container">
      <h2>En 2 minutos sabremos si calificas</h2>
      <p class="muted section-sub">
        Estas son las preguntas más comunes. Si no tienes todo a mano, no pasa nada: empezamos con lo básico.
      </p>

      <div class="grid" style="margin-top:14px">
        <div class="card">
          <h2>¿Quién debe considerar ACA?</h2>
          <ul class="list">
            {who.map((x) => <li>{x}</li>)}
          </ul>
        </div>

        <div class="card">
          <h2>Lo que te pediremos</h2>
          <ul class="list">
            {ask.map((x) => <li>{x}</li>)}
          </ul>
        </div>

        <div class="card">
          <h2>Periodo Especial de Inscripción (SEP)</h2>
          <p class="muted">
            Si tuviste un cambio importante, es posible que puedas inscribirte fuera del periodo abierto.
          </p>
          <ul class="list">
            {sep.map((x) => <li>{x}</li>)}
          </ul>
          <p class="small" style="margin-top:10px">
            ¿No estás seguro? Escríbenos y lo confirmamos contigo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="prose-container">
      <h2>Por qué familias hispanas nos eligen</h2>
      <p class="muted section-sub">
        No vendemos por presión. Nuestra meta es que entiendas tu opción y te quede un plan que sí sirva.
      </p>

      <div class="feature-grid" style="margin-top:14px">
        <div class="card tight">
          <h3>En español (de verdad)</h3>
          <p class="muted">Explicaciones claras, sin palabras raras, y paciencia para preguntas.</p>
        </div>
        <div class="card tight">
          <h3>Subsidios y costos</h3>
          <p class="muted">Te decimos el costo real, deducibles, máximos y lo que cambia con el ingreso.</p>
        </div>
        <div class="card tight">
          <h3>Doctores y medicinas</h3>
          <p class="muted">Verificamos red y medicamentos para que el plan funcione en tu vida diaria.</p>
        </div>
      </div>

      <div class="cta-band" style="margin-top:18px">
        <h3 style="margin:0 0 8px">¿Listo para comparar?</h3>
        <p>
          Escríbenos por WhatsApp o llámanos. Si ya tienes un plan, también te ayudamos a revisarlo y evitar sorpresas.
        </p>
        <div class="cta-row" style="margin-top:12px">
          <a class="btn btn-primary" href="/es/compare/">Comparar planes</a>
          <a class="btn btn-outline" href={waHref} rel="noopener">Hablar por WhatsApp</a>
          <a class="btn btn-outline" href="/es/faq/">Preguntas frecuentes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="prose-container">
      <h2>Preguntas frecuentes</h2>
      <FaqAccordion items={faqs} />
      <p class="small" style="margin-top:14px">
        Nota: No estamos afiliados al gobierno. “Obamacare” se refiere a planes del Marketplace bajo la ACA.
      </p>
    </div>
  </section>
</SiteShell>
