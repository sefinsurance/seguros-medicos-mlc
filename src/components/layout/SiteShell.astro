---
import Header from "./Header.astro";
import Footer from "./Footer.astro";

const { title, description, lang = "en", canonical } = Astro.props;

const site = "https://obamacarelocal.com";
const path = Astro.url.pathname;
const isEs = path.startsWith("/es");
const isEn = path.startsWith("/en");

const altEs = isEs ? `${site}${path}` : `${site}/es${path === "/" ? "" : path.replace(/^\/en/, "")}`;
const altEn = isEn ? `${site}${path}` : `${site}/en${path === "/" ? "" : path.replace(/^\/es/, "")}`;
const xDefault = `${site}/`;
const canon = canonical || `${site}${path}`;
---
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {title && <title>{title}</title>}
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canon} />

    <link rel="alternate" hreflang="es" href={altEs} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="x-default" href={xDefault} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
