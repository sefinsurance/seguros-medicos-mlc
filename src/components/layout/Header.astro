---
const { lang = 'en' } = Astro.props;

const nav = [
  { href: `/${lang}/aca/`, label: lang === 'es' ? 'Obamacare (ACA)' : 'ACA (Obamacare)' },
  { href: `/${lang}/medicare/`, label: 'Medicare' },
  { href: `/${lang}/life/`, label: lang === 'es' ? 'Vida' : 'Life' },
  { href: `/${lang}/dental/`, label: 'Dental' },
  { href: `/${lang}/faq/`, label: lang === 'es' ? 'Preguntas' : 'FAQ' },
];

const phoneDisplay = '877-458-2557';
const phoneHref = 'tel:+18774582557';
const waHref = 'https://wa.me/18774582557';
---

<header class="top">
  <div class="bar">
    <div class="bar__left">
      <span class="bar__pill">{lang === 'es' ? 'Se habla español' : 'Hablamos Español'}</span>
      <span class="bar__sep">•</span>
      <span class="bar__text">{lang === 'es' ? 'Atención familiar y sin presión' : 'Family-first, no-pressure help'}</span>
    </div>

    <div class="bar__right">
      <a class="bar__link" href={phoneHref} aria-label={lang === 'es' ? 'Llamar a MLC Insurance' : 'Call MLC Insurance'}>
        <span class="bar__label">{lang === 'es' ? 'Llámanos' : 'Call'}</span>
        <span class="bar__value">{phoneDisplay}</span>
      </a>
      <a class="bar__btn" href={waHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        WhatsApp
      </a>
    </div>
  </div>

  <div class="nav">
    <a class="brand" href={`/${lang}/`} aria-label="MLC Insurance">
      <img class="brand__logo" src="/images/brand/mlc-logo.webp" width="48" height="48" alt="MLC Insurance logo" loading="eager" decoding="async" />
      <div class="brand__text">
        <div class="brand__name">MLC Insurance</div>
        <div class="brand__tag">{lang === 'es' ? 'Seguros de salud para tu familia' : 'Health coverage for your family'}</div>
      </div>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {nav.map((item) => (
        <a class="nav__link" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="nav__cta">
      <a class="cta" href={`/${lang}/compare/`}>{lang === 'es' ? 'Comparar planes' : 'Compare plans'}</a>
    </div>
  </div>
</header>

<style>
  .top{position:sticky;top:0;z-index:50;backdrop-filter:saturate(160%) blur(10px)}
  .bar{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:10px 18px;background:linear-gradient(90deg,var(--brand-900),var(--brand-800));color:white;border-bottom:1px solid rgba(255,255,255,.14)}
  .bar__left{display:flex;align-items:center;gap:10px;min-width:0}
  .bar__pill{font-weight:900;font-size:12px;letter-spacing:.02em;background:rgba(255,255,255,.14);padding:6px 10px;border-radius:999px;white-space:nowrap}
  .bar__sep{opacity:.7}
  .bar__text{opacity:.92;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar__right{display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end}
  .bar__link{display:flex;align-items:baseline;gap:8px;color:white;text-decoration:none;font-weight:900}
  .bar__label{font-size:12px;opacity:.85}
  .bar__value{font-size:14px;letter-spacing:.02em}
  .bar__btn{display:inline-flex;align-items:center;justify-content:center;height:34px;padding:0 12px;border-radius:10px;background:var(--accent-500);color:#04212a;font-weight:900;text-decoration:none}

  .nav{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:14px 18px;background:rgba(255,255,255,.9);border-bottom:1px solid var(--line)}
  .brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:inherit;min-width:220px}
  .brand__logo{border-radius:999px;box-shadow:0 10px 30px rgba(0,0,0,.10)}
  .brand__name{font-weight:900;letter-spacing:.01em}
  .brand__tag{font-size:12px;opacity:.72}

  .nav__links{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
  .nav__link{color:var(--text);text-decoration:none;font-weight:900;font-size:14px;padding:8px 10px;border-radius:10px}
  .nav__link:hover{background:rgba(0,0,0,.05)}

  .cta{display:inline-flex;align-items:center;justify-content:center;height:40px;padding:0 14px;border-radius:12px;background:linear-gradient(90deg,var(--brand-800),var(--brand-700));color:white;font-weight:900;text-decoration:none;box-shadow:0 12px 25px rgba(0,0,0,.10)}
  .cta:hover{filter:brightness(1.05)}

  @media (max-width: 860px){
    .bar{padding:10px 14px}
    .nav{padding:12px 14px;flex-wrap:wrap}
    .brand{min-width:auto}
    .nav__links{width:100%;order:3;padding-top:8px}
    .nav__cta{order:2}
  }

  @media (max-width: 520px){
    .bar__text{display:none}
  }
</style>
