---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const t = {
  brand: 'MLC Insurance',
  phone: '877-458-2557',
  nav: isEs
    ? [
        { href: '/es/aca', label: 'Obamacare' },
        { href: '/es/medicare', label: 'Medicare' },
        { href: '/es/dental', label: 'Dental' },
        { href: '/es/faq', label: 'Preguntas' },
      ]
    : [
        { href: '/en/aca', label: 'ACA / Obamacare' },
        { href: '/en/medicare', label: 'Medicare' },
        { href: '/en/dental', label: 'Dental' },
        { href: '/en/faq', label: 'FAQ' },
      ],
  cta: isEs ? 'Llamar o enviar texto' : 'Call / Text',
  whatsapp: 'WhatsApp',
};

const digits = t.phone.replace(/[^0-9]/g, '');
const phoneHref = `tel:+1${digits}`;
const smsHref = `sms:+1${digits}`;
// WhatsApp deep-link. (If WhatsApp is not installed, it falls back to web.)
const waHref = `https://wa.me/1${digits}`;
---

<header>
  <div class="container bar">
    <a class="brand" href={isEs ? '/es' : '/en'} aria-label={`${t.brand} home`}>
      <span class="logo" aria-hidden="true">MLC</span>
      <span>
        <b>{t.brand}</b>
        <small>{isEs ? 'Atención familiar · Hablamos español' : 'Family-focused · Bilingual support'}</small>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      {t.nav.map((item) => (
        <a class="navlink" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="cta">
      <a class="btn btn-pill btn-teal" href={phoneHref}>{t.cta}</a>
      <a class="btn btn-pill btn-light" href={waHref} rel="noopener">{t.whatsapp}</a>
    </div>

    <details class="menu">
      <summary aria-label="Menu">☰</summary>
      <div class="panel">
        {t.nav.map((item) => (
          <a class="panelLink" href={item.href}>{item.label}</a>
        ))}
        <div class="panelCtas">
          <a class="btn btn-pill btn-teal" href={phoneHref}>{t.cta}</a>
          <a class="btn btn-pill btn-light" href={smsHref}>{isEs ? 'Texto' : 'Text'}</a>
          <a class="btn btn-pill btn-light" href={waHref} rel="noopener">WhatsApp</a>
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  header{position:sticky;top:0;z-index:50;background:rgba(11,17,22,.72);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,.12)}
  .bar{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:10px 0}
  .brand{display:flex;align-items:center;gap:10px;min-width:240px}
  .logo{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,var(--brand),var(--accent));display:flex;align-items:center;justify-content:center;font-weight:950;color:#051015;letter-spacing:.05em}
  .brand b{display:block;line-height:1.1}
  .brand small{display:block;opacity:.85;font-size:12px;margin-top:2px}
  .nav{display:flex;gap:14px;align-items:center}
  .navlink{opacity:.9;font-weight:800;font-size:14px;padding:10px 10px;border-radius:12px}
  .navlink:hover{background:rgba(255,255,255,.10);opacity:1}
  .cta{display:flex;gap:10px;align-items:center}
  .menu{display:none}

  @media (max-width: 920px){
    .nav{display:none}
    .cta{display:none}
    .menu{display:block}
    summary{list-style:none;cursor:pointer;padding:10px 12px;border-radius:12px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.08);font-weight:900}
    summary::-webkit-details-marker{display:none}
    .panel{position:absolute;right:16px;top:64px;width:min(92vw,360px);background:#0b1116;border:1px solid rgba(255,255,255,.16);border-radius:18px;box-shadow:0 20px 50px rgba(0,0,0,.45);padding:12px}
    .panelLink{display:block;padding:12px 12px;border-radius:14px;font-weight:900;opacity:.92}
    .panelLink:hover{background:rgba(255,255,255,.08);opacity:1}
    .panelCtas{display:grid;gap:10px;padding:10px 6px 6px}
  }
</style>
