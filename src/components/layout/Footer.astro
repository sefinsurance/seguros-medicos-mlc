---
const { lang } = Astro.props;
const text = lang === 'es'
  ? {
      blurb: 'Seguro médico, Medicare, Vida y Dental en toda Florida.',
      hours: 'Lunes a Viernes · 9am–6pm',
      cta: 'Escríbenos por WhatsApp',
      rights: 'Todos los derechos reservados.'
    }
  : {
      blurb: 'Health insurance, Medicare, Life & Dental across Florida.',
      hours: 'Monday to Friday · 9am–6pm',
      cta: 'Message us on WhatsApp',
      rights: 'All rights reserved.'
    };

const waText = lang === 'es'
  ? 'Hola, quiero ayuda con mi seguro médico en Florida.'
  : 'Hi, I would like help with health insurance in Florida.';
const waHref = `https://wa.me/18774582557?text=${encodeURIComponent(waText)}`;
---
<footer style="background:var(--brand);color:#fff;padding:48px 0;margin-top:80px">
  <div class="container" style="display:grid;gap:16px">
    <div style="display:flex;gap:12px;align-items:center">
      <img src="/images/logo.png" width="44" height="44" style="background:#fff;border-radius:50%;padding:3px">
      <div>
        <strong style="font-size:12px;letter-spacing:.14em;text-transform:uppercase">Seguros Médicos</strong>
        <div class="small" style="color:rgba(255,255,255,.85)">{text.blurb}</div>
      </div>
    </div>

    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
      <a class="btn btn-primary" href={waHref}>{text.cta}</a>
      <a class="btn btn-light" href="tel:+18774582557">1-877-458-2557</a>
      <span class="small" style="color:rgba(255,255,255,.85)">{text.hours}</span>
    </div>

    <div class="small" style="color:rgba(255,255,255,.7)">
      © {new Date().getFullYear()} Seguros Médicos · {text.rights}
    </div>
  </div>
</footer>
