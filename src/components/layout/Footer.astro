---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const phone = '877-458-2557';
const digits = phone.replace(/[^0-9]/g,'');
const phoneHref = `tel:+1${digits}`;
const smsHref = `sms:+1${digits}`;
const waHref = `https://wa.me/1${digits}`;

const states = [
  { code: 'FL', name: 'Florida' },
  { code: 'TX', name: 'Texas' },
  { code: 'SC', name: 'South Carolina' },
  { code: 'TN', name: 'Tennessee' },
  { code: 'NC', name: 'North Carolina' },
];
---

<footer>
  <div class="container wrap">
    <div class="col">
      <div class="brand">
        <span class="logo" aria-hidden="true">MLC</span>
        <div>
          <b>MLC Insurance</b>
          <div class="muted">{isEs ? 'Seguro de salud · Medicare · Dental · Vida' : 'Health · Medicare · Dental · Life'}</div>
        </div>
      </div>

      <p class="muted" style="margin:12px 0 0">
        {isEs
          ? 'Somos una agencia familiar con enfoque hispano. Comparamos opciones y te ayudamos a elegir un plan del Marketplace que se ajuste a tu familia y tu presupuesto.'
          : 'A family-focused agency with a strong Hispanic community presence. We compare options and help you choose a Marketplace plan that fits your family and budget.'}
      </p>

      <div class="ctas">
        <a class="btn btn-pill btn-teal" href={phoneHref}>{isEs ? 'Llamar' : 'Call'} {phone}</a>
        <a class="btn btn-pill btn-light" href={smsHref}>{isEs ? 'Texto' : 'Text'}</a>
        <a class="btn btn-pill btn-light" href={waHref} rel="noopener">WhatsApp</a>
      </div>

      <p class="fine">
        {isEs
          ? 'Nota: No estamos afiliados al gobierno. “Obamacare” se refiere a planes de la Ley de Cuidado de Salud Asequible (ACA).'
          : 'Note: We are not affiliated with the government. “Obamacare” refers to Affordable Care Act (ACA) Marketplace plans.'}
      </p>
    </div>

    <div class="col">
      <h4>{isEs ? 'Servicios' : 'Services'}</h4>
      <ul class="list">
        <li>{isEs ? 'Marketplace (ACA / Obamacare): todos los planes disponibles' : 'Marketplace (ACA / Obamacare): all available plans'}</li>
        <li>{isEs ? 'Ayuda con elegibilidad, SEP y cambios de ingreso' : 'Help with eligibility, SEP, and income changes'}</li>
        <li>{isEs ? 'Medicare (según disponibilidad)' : 'Medicare (where available)'}</li>
        <li>{isEs ? 'Dental y Vida (opciones individuales)' : 'Dental & Life (individual options)'}</li>
      </ul>

      <h4 style="margin-top:18px">{isEs ? 'Estados' : 'States'}</h4>
      <div class="chips">
        {states.map((s) => (
          <span class="chip">{s.code}</span>
        ))}
      </div>
      <div class="muted" style="margin-top:8px;font-size:13px">
        {states.map((s) => s.name).join(' · ')}
      </div>
    </div>

    <div class="col">
      <h4>{isEs ? 'Enlaces' : 'Links'}</h4>
      <ul class="list">
        <li><a href={isEs ? '/es/aca' : '/en/aca'}>{isEs ? 'Obamacare' : 'ACA / Obamacare'}</a></li>
        <li><a href={isEs ? '/es/compare' : '/en/compare'}>{isEs ? 'Comparar' : 'Compare'}</a></li>
        <li><a href={isEs ? '/es/faq' : '/en/faq'}>{isEs ? 'Preguntas frecuentes' : 'FAQ'}</a></li>
        <li><a href="/about">{isEs ? 'Sobre nosotros' : 'About'}</a></li>
      </ul>

      <div class="fine" style="margin-top:18px">
        © {new Date().getFullYear()} MLC Insurance. {isEs ? 'Todos los derechos reservados.' : 'All rights reserved.'}
      </div>
    </div>
  </div>
</footer>

<style>
  footer{background:#ffffff;border-top:1px solid rgba(15,23,42,.10);margin-top:40px}
  .wrap{display:grid;gap:18px;padding:28px 0}
  @media(min-width:900px){.wrap{grid-template-columns:1.3fr .9fr .7fr}}
  .brand{display:flex;gap:10px;align-items:center}
  .logo{width:44px;height:44px;border-radius:16px;background:linear-gradient(135deg,var(--brand),var(--accent));display:flex;align-items:center;justify-content:center;font-weight:950;color:#061018;letter-spacing:.06em}
  b{font-weight:950}
  h4{margin:0 0 10px;color:#0b1116}
  .muted{color:rgba(15,23,42,.70)}
  .ctas{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px}
  .list{margin:0;padding-left:18px;color:rgba(15,23,42,.76)}
  .list li{margin:8px 0}
  .list a{color:inherit;text-decoration:underline;text-decoration-color:rgba(11,79,108,.25)}
  .chips{display:flex;flex-wrap:wrap;gap:8px}
  .chip{padding:6px 10px;border-radius:999px;background:rgba(11,79,108,.08);border:1px solid rgba(11,79,108,.12);color:var(--brand2);font-weight:900;font-size:12px}
  .fine{color:rgba(15,23,42,.62);font-size:12px;line-height:1.4;margin-top:12px}
</style>
