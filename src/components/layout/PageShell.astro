---
import SiteShell from "./SiteShell.astro";
const {
  lang = "es",
  t,
  kicker,
  title,
  desc,
  ctaHref,
  ctaText,
  secondaryHref,
  secondaryText,
  links = [],
  canonical,
} = Astro.props;
---

<SiteShell lang={lang} title={title ?? "Obamacare Local | MLC Insurance"} description={desc ?? title} canonical={canonical}>
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-panel surface">
        <div class="page-meta-row">
          <div class="breadcrumb">
            <a href={`/${lang}/`}>{t?.nav?.home ?? (lang === "en" ? "Home" : "Inicio")}</a>
            <span aria-hidden="true">•</span>
            <span>{kicker}</span>
          </div>
          <a class="back-home" href={`/${lang}/`}>
            {lang === "en" ? "Home" : "Inicio"}
          </a>
        </div>

        <div class="page-kicker">{kicker}</div>
        <h1 class="page-title">{title}</h1>
        {desc && <p class="page-lead">{desc}</p>}

        {(ctaHref || secondaryHref) && (
          <div class="pageactions">
            {ctaHref && ctaText && <a class="btn btn-primary" href={ctaHref}>{ctaText}</a>}
            {secondaryHref && secondaryText && <a class="btn btn-secondary" href={secondaryHref}>{secondaryText}</a>}
            <a class="btn btn-ghost" href="tel:+18774582557">{lang === "en" ? "Call 877-458-2557" : "Llamar 877-458-2557"}</a>
          </div>
        )}

        {links.length > 0 && (
          <div class="pill-links page-quicklinks">
            {links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <main class="pagewrap">
    <div class="container">
      <div class="content-stack">
        <slot />
      </div>
    </div>
  </main>
</SiteShell>

<style>
  .page-hero{
    position:relative;
    padding:40px 0 18px;
  }
  .page-hero::before{
    content:"";
    position:absolute;
    inset:0;
    background:
      radial-gradient(760px 340px at 50% 18%, rgba(255,255,255,.94), rgba(255,255,255,0) 68%),
      radial-gradient(900px 460px at 50% 78%, rgba(218,229,245,.18), rgba(218,229,245,0) 66%);
    pointer-events:none;
  }
  .page-hero .container{position:relative;z-index:1;}
  .page-hero-panel{
    padding:26px 28px 28px;
    max-width:1160px;
    margin:0 auto;
  }
  .page-meta-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:16px;
    margin-bottom:14px;
  }
  .back-home{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:40px;
    padding:0 16px;
    border-radius:999px;
    background:rgba(20,63,105,.06);
    border:1px solid rgba(18,50,79,.08);
    color:#1e467a;
    font-weight:800;
    font-size:14px;
  }
  .page-kicker{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:48px;
    padding:12px 20px;
    border-radius:999px;
    background: linear-gradient(180deg, #2e7ada 0%, #2569bf 100%);
    color:#fff;
    font-weight:700;
    font-size:16px;
    box-shadow:0 14px 28px rgba(16,47,91,.14), inset 0 1px 0 rgba(255,255,255,.18);
  }
  .page-title{
    margin:22px 0 14px;
  }
  .page-lead{
    max-width:860px;
    margin:0;
  }
  .page-quicklinks{
    margin-top:18px;
    justify-content:flex-start;
  }
  @media(max-width:760px){
    .page-hero-panel{padding:22px 18px 22px;}
    .page-meta-row{flex-direction:column;align-items:flex-start;}
    .page-kicker{font-size:14px;min-height:44px;padding:10px 16px;}
  }
</style>
