---
import ServiceCard from "./ServiceCard.astro";
const phoneDisplay = "877-458-2557";
const phoneDial = "+18774582557";
const whatsappLink = "https://wa.me/18774582557";
---
<section class="hero">
  <div class="mlc-container hero__inner">
    <div class="pill-top">• Se habla español • Atención familiar y sin presión</div>

    <h1>Seguro médico, sin estrés</h1>
    <p class="lead">
      Te ayudamos a comparar opciones de Obamacare (ACA) y Medicare. Respuestas claras,
      rápido por llamada, texto o WhatsApp.
    </p>

    <div class="cta">
      <a class="btn btn--wa" href={whatsappLink} target="_blank" rel="noreferrer">
        <img src="/icons/whatsapp.svg" class="btn__svg" alt="WhatsApp" />
        Hablar por WhatsApp
      </a>
      <a class="btn btn--navy" href={`tel:${phoneDial}`}>
        Llámanos {phoneDisplay}
      </a>
    </div>

    <div class="cards">
      <ServiceCard title="Obamacare (ACA)" subtitle="Subsidios y planes del Marketplace" icon="/icons/aca.svg" href="/obamacare" />
      <ServiceCard title="Medicare" subtitle="MA/MAPD y ventanas de inscripción" icon="/icons/medicare.svg" href="/medicare" />
      <ServiceCard title="Vida" subtitle="Protege tu familia" icon="/icons/life.svg" href="/vida" />
      <ServiceCard title="Dental y Visión" subtitle="Planes combinados" icon="/icons/dental-vision.svg" href="/dental-vision" />
    </div>
  </div>
</section>

<style>
.hero{ padding: 64px 0 110px; }
.hero__inner{ text-align:center; }

.pill-top{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding: 14px 30px;
  border-radius: 999px;
  font-weight:900;
  color:#fff;
  background: linear-gradient(180deg, #2a68b8, #1f4f93);
  box-shadow: 0 18px 34px rgba(9,31,61,.18);
  margin: 10px auto 28px;
}

h1{
  font-family: ui-serif, Georgia, "Times New Roman", Times, serif;
  font-weight: 900;
  letter-spacing: -1px;
  font-size: clamp(44px, 5.3vw, 72px);
  margin: 0;
  color: #0b223a;
}

.lead{
  max-width: 900px;
  margin: 18px auto 0;
  font-size: 18px;
  line-height: 1.55;
  color: rgba(35,74,107,0.92);
}

.cta{
  display:flex;
  gap:18px;
  justify-content:center;
  margin: 30px 0 44px;
  flex-wrap:wrap;
}

.btn{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding: 14px 28px;
  border-radius: 999px;
  font-weight: 900;
  box-shadow: var(--shadow-cta);
  border: 1px solid rgba(12,34,58,0.10);
  white-space:nowrap;
}

.btn--wa{
  background: var(--wa);
  color:#fff;
  border-color: transparent;
}
.btn--wa:hover{ background: var(--wa-deep); }

.btn--navy{
  background: linear-gradient(180deg, #2a68b8, #1f4f93);
  color:#fff;
  border-color: transparent;
}
.btn--navy:hover{ background: linear-gradient(180deg, #255da4, #173e75); }

.btn__svg{ width:18px; height:18px; filter: brightness(0) invert(1); }

.cards{
  width: min(1180px, 100%);
  margin: 0 auto;
  display:grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 22px;
  align-items:stretch;
}

@media (max-width: 1024px){
  .cards{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 560px){
  .cards{ grid-template-columns: 1fr; }
}
</style>
