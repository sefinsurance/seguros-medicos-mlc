---
import ServiceCard from "./ServiceCard.astro";
---
<section class="hero">
  <div class="mlc-container hero__inner">
    <div class="pill-top">• Se habla español • Atención familiar y sin presión</div>

    <h1>Seguro médico, sin estrés</h1>
    <p class="lead">
      Te ayudamos a comparar opciones de Obamacare (ACA) y Medicare. Respuestas claras,
      rápido por llamada, texto o WhatsApp.
    </p>

    <div class="cta">
      <a class="btn btn--wa" href="https://wa.me/18774582557" target="_blank" rel="noreferrer">
        <img src="/icons/whatsapp.svg" class="btn__svg" alt="WhatsApp" />
        Hablar por WhatsApp
      </a>
      <a class="btn btn--navy" href="/comparar">Comparar planes</a>
    </div>

    <div class="cards">
      <ServiceCard title="Obamacare (ACA)" subtitle="Subsidios y planes del Marketplace" icon="/icons/aca.svg" href="/obamacare" />
      <ServiceCard title="Medicare" subtitle="MA/MAPD y ventanas de inscripción" icon="/icons/medicare.svg" href="/medicare" />
      <ServiceCard title="Vida" subtitle="Protege tu familia" icon="/icons/life.svg" href="/vida" />
      <ServiceCard title="Dental y Visión" subtitle="Planes combinados" icon="/icons/dental-vision.svg" href="/dental-vision" />
    </div>
  </div>
</section>

<style>
.hero{padding:70px 0 110px;position:relative}
.hero__inner{text-align:center}
.pill-top{display:inline-flex;align-items:center;justify-content:center;padding:14px 28px;border-radius:999px;font-weight:800;color:#fff;background:var(--navy);box-shadow:0 18px 34px rgba(9,31,61,.18);margin:6px auto 28px}
h1{font-family:ui-serif,Georgia,"Times New Roman",Times,serif;font-weight:900;letter-spacing:-1px;font-size:clamp(42px,5.4vw,68px);margin:0;color:#0b223a;text-shadow:0 1px 0 rgba(255,255,255,.55)}
.lead{max-width:880px;margin:18px auto 0;font-size:18px;line-height:1.55;color:#234a6b}
.cta{display:flex;gap:16px;justify-content:center;margin:30px 0 40px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 26px;border-radius:999px;font-weight:900;border:1px solid rgba(12,34,58,.10);box-shadow:0 18px 34px rgba(9,31,61,.16);white-space:nowrap}
.btn--wa{background:var(--wa);color:#fff;border-color:transparent}
.btn--wa:hover{background:var(--wa-deep)}
.btn--navy{background:var(--navy);color:#fff;border-color:transparent}
.btn--navy:hover{background:var(--navy-deep)}
.btn__svg{width:18px;height:18px;filter:brightness(0) invert(1)}
.cards{width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:22px;align-items:stretch}
@media (max-width:1024px){.cards{grid-template-columns:repeat(2,minmax(0,1fr))}}
@media (max-width:560px){.cards{grid-template-columns:1fr}}
</style>