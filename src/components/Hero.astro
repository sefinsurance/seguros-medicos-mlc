---
import ServiceCard from "./ServiceCard.astro";
---
<section class="hero">
  <div class="container hero__inner">
    <div class="pill-top">• Se habla español • Atención familiar y sin presión</div>

    <h1>Seguro médico, sin estrés</h1>
    <p class="lead">
      Te ayudamos a comparar opciones de Obamacare (ACA) y Medicare. Respuestas claras,
      rápido por llamada, texto o WhatsApp.
    </p>

    <div class="cta">
      <a class="btn btn--wa" href="https://wa.me/1XXXXXXXXXX" target="_blank" rel="noreferrer">
        <span class="btn__ico">🟢</span> Hablar por WhatsApp
      </a>
      <a class="btn btn--navy" href="/comparar">Comparar planes</a>
    </div>

    <div class="cards">
      <ServiceCard
        title="Obamacare (ACA)"
        subtitle="Subsidios y planes del Marketplace"
        icon="/icons/aca.svg"
        href="/obamacare"
      />
      <ServiceCard
        title="Medicare"
        subtitle="MA/MAPD y ventanas de inscripción"
        icon="/icons/medicare.svg"
        href="/medicare"
      />
      <ServiceCard
        title="Vida"
        subtitle="Protege tu familia"
        icon="/icons/life.svg"
        href="/vida"
      />
      <ServiceCard
        title="Dental y Visión"
        subtitle="Planes combinados"
        icon="/icons/dental-vision.svg"
        href="/dental-vision"
      />
    </div>
  </div>
</section>

<style>
.hero{ padding: 54px 0 84px; }
.hero__inner{
  text-align:center;
}

.pill-top{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding: 14px 26px;
  border-radius: 999px;
  font-weight:800;
  color:#fff;
  background: var(--navy);
  box-shadow: 0 16px 28px rgba(9,31,61,.14);
  margin: 10px auto 26px;
}

h1{
  font-family: ui-serif, Georgia, "Times New Roman", Times, serif;
  font-weight: 800;
  letter-spacing: -0.8px;
  font-size: clamp(38px, 5.3vw, 64px);
  margin: 0;
  color:#0f2a44;
}
.lead{
  max-width: 820px;
  margin: 16px auto 0;
  font-size: 18px;
  line-height: 1.45;
  color:#2a4a67;
}

.cta{
  display:flex;
  gap:16px;
  justify-content:center;
  margin: 26px 0 34px;
  flex-wrap:wrap;
}
.btn{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding: 14px 22px;
  border-radius: 999px;
  font-weight: 900;
  border: 1px solid rgba(18,50,79,0.10);
  box-shadow: 0 16px 28px rgba(9,31,61,.12);
}
.btn--wa{ background: var(--wa); color:#fff; border-color: rgba(0,0,0,0); }
.btn--wa:hover{ background: var(--wa-deep); }
.btn--navy{ background: var(--navy); color:#fff; border-color: rgba(0,0,0,0); }
.btn--navy:hover{ background: var(--navy-deep); }
.btn__ico{ font-size:14px; }

.cards{
  width: min(1120px, 100%);
  margin: 0 auto;
  display:grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  justify-content:center;
  align-items:stretch;
}

@media (max-width: 1024px){
  .cards{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 560px){
  .cards{ grid-template-columns: 1fr; }
}
</style>
