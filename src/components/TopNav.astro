---
const phoneDisplay = "877-458-2557";
const phoneDial = "+18774582557";
---
<header class="topbar">
  <div class="mlc-container topbar__inner">
    <a class="brand" href="/">
      <img class="brand__logo" src="/icons/mlc-logo.svg" alt="MLC Insurance" />
      <div class="brand__text">
        <div class="brand__name">MLC Insurance</div>
        <div class="brand__tag">Seguros de salud para tu familia</div>
      </div>
    </a>

    <nav class="menu" aria-label="Primary">
      <a href="/obamacare">Obamacare</a>
      <a href="/medicare">Medicare</a>
      <a href="/vida">Vida</a>
      <a href="/dental-vision">Dental y Visión</a>
    </nav>

    <div class="actions">
      <a class="pill pill--navy" href="/comparar">Comparar</a>
      <a class="pill pill--phone" href={`tel:${phoneDial}`}>
        <img src="/icons/whatsapp.svg" class="pill__svg" alt="" />
        {phoneDisplay}
      </a>
    </div>
  </div>
  <div class="topbar__rule" aria-hidden="true"></div>
</header>

<style>
.topbar{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.86);backdrop-filter:blur(16px)}
.topbar__inner{display:flex;align-items:center;gap:20px;padding:16px 0}
.topbar__rule{height:2px;background:var(--navy);opacity:.95}
.brand{display:flex;align-items:center;gap:12px;min-width:270px}
.brand__logo{width:44px;height:44px}
.brand__name{font-weight:900;letter-spacing:-.2px}
.brand__tag{font-size:13px;color:var(--muted);margin-top:2px}
.menu{display:flex;gap:22px;align-items:center;justify-content:center;flex:1;font-weight:700;color:#163d63}
.menu a{padding:10px 6px;border-radius:10px}
.menu a:hover{background:rgba(31,79,147,.07)}
.actions{display:flex;gap:12px;align-items:center}
.pill{display:inline-flex;align-items:center;gap:10px;padding:12px 18px;border-radius:999px;font-weight:900;box-shadow:0 14px 28px rgba(9,31,61,.14);white-space:nowrap;border:1px solid rgba(12,34,58,.08)}
.pill--navy{background:var(--navy);color:#fff;border-color:transparent}
.pill--navy:hover{background:var(--navy-deep)}
.pill--phone{background:var(--wa);color:#fff;border-color:transparent;padding-inline:20px}
.pill--phone:hover{background:var(--wa-deep)}
.pill__svg{width:18px;height:18px;filter:brightness(0) invert(1)}
@media (max-width:980px){.menu{display:none}.brand{min-width:unset}}
</style>