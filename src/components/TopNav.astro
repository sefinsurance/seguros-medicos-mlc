---
const phone = "877-458-2557";
---
<header class="topbar">
  <div class="mlc-container topbar__inner">
    <a class="brand" href="/">
      <img class="brand__logo" src="/icons/mlc-logo.svg" alt="MLC Insurance" />
      <div class="brand__text">
        <div class="brand__name">MLC Insurance</div>
        <div class="brand__tag">Seguros de salud para tu familia</div>
      </div>
    </a>

    <nav class="menu" aria-label="Primary">
      <a href="/obamacare">Obamacare</a>
      <a href="/medicare">Medicare</a>
      <a href="/vida">Vida</a>
      <a href="/dental-vision">Dental y Visión</a>
    </nav>

    <div class="actions">
      <a class="pill pill--navy" href="/comparar">Comparar</a>
      <a class="pill pill--wa" href="https://wa.me/1XXXXXXXXXX" target="_blank" rel="noreferrer">
        <span class="ico">🟢</span> WhatsApp
      </a>
      <a class="pill pill--wa pill--phone" href={`tel:${phone.replace(/[^0-9]/g,'')}`}>
        <span class="ico">☎</span> {phone}
      </a>
    </div>
  </div>
  <div class="topbar__rule" aria-hidden="true"></div>
</header>

<style>
.topbar{
  position:sticky;
  top:0;
  z-index:50;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(14px);
}
.topbar__inner{
  display:flex;
  align-items:center;
  gap:18px;
  padding:16px 0;
}
.topbar__rule{
  height:2px; /* half as wide */
  background: var(--navy);
  opacity: .95;
}

.brand{ display:flex; align-items:center; gap:12px; min-width:260px; }
.brand__logo{ width:42px; height:42px; }
.brand__name{ font-weight:800; letter-spacing:-.2px; }
.brand__tag{ font-size:13px; color: var(--muted); margin-top:2px; }

.menu{
  display:flex;
  gap:22px;
  align-items:center;
  justify-content:center;
  flex:1;
  font-weight:600;
  color:#163d63;
}
.menu a{ padding:10px 6px; border-radius:10px; }
.menu a:hover{ background: rgba(31,79,147,0.07); }

.actions{ display:flex; gap:10px; align-items:center; }
.pill{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:12px 16px;
  border-radius:999px;
  font-weight:800;
  box-shadow: 0 10px 20px rgba(9,31,61,.10);
  white-space:nowrap;
}
.pill--navy{ background: var(--navy); color:#fff; }
.pill--navy:hover{ background: var(--navy-deep); }
.pill--wa{ background: var(--wa); color:#fff; }
.pill--wa:hover{ background: var(--wa-deep); }
.pill--phone{ padding-inline:18px; }
.ico{ font-size:14px; opacity:.9; }

@media (max-width: 980px){
  .menu{ display:none; }
  .brand{ min-width:unset; }
}
@media (max-width: 560px){
  .actions .pill--navy{ display:none; }
}
</style>
