---
const phone = "877-458-2557";
---
<header class="topbar">
  <div class="container topbar__inner">
    <a class="brand" href="/">
      <img class="brand__logo" src="/icons/mlc-logo.svg" alt="MLC Insurance" />
      <div class="brand__text">
        <div class="brand__name">MLC Insurance</div>
        <div class="brand__tag">Seguros de salud para tu familia</div>
      </div>
    </a>

    <nav class="menu" aria-label="Primary">
      <a href="/obamacare">Obamacare</a>
      <a href="/medicare">Medicare</a>
      <a href="/vida">Vida</a>
      <a href="/dental-vision">Dental y Visión</a>
    </nav>

    <div class="actions">
      <a class="pill pill--wa" href="https://wa.me/18774582557" target="_blank" rel="noreferrer">
        <img class="ico" src="/icons/whatsapp.svg" alt="" /> 877-458-2557
      </a>
    </div>
  </div>
</header>

<style>
.topbar{
  position:sticky;
  top:0;
  z-index:50;
  background: var(--topbar);
}
.topbar__inner{
  display:flex;
  align-items:center;
  gap:18px;
  padding:18px 0;
}

.brand{ display:flex; align-items:center; gap:12px; min-width:260px; }
.brand__logo{ width:42px; height:42px; filter: drop-shadow(0 10px 18px rgba(0,0,0,0.18)); }
.brand__name{ font-weight:900; letter-spacing:-.2px; color:#fff; }
.brand__tag{ font-size:13px; color: rgba(255,255,255,0.78); margin-top:2px; }

.menu{
  font-size:16px;
  display:flex;
  gap:22px;
  align-items:center;
  justify-content:center;
  flex:1;
  font-weight:800;
  color:#fff;
}
.menu a{ padding:10px 6px; border-radius:10px; }
.menu a:hover{ background: rgba(255,255,255,0.10); }

.actions{ display:flex; gap:10px; align-items:center; }
.pill{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:12px 18px;
  border-radius:999px;
  font-weight:900;
  box-shadow: 0 14px 28px rgba(0,0,0,0.22);
  white-space:nowrap;
}

.pill--navy{ background: var(--navy); color:#fff; }
.pill--navy:hover{ background: var(--navy-deep); }
.pill--wa{ background: var(--wa); color:#fff; }
.pill--wa:hover{ filter: brightness(.98); }
.pill--phone{ padding-inline:18px; }
.ico{ width:18px; height:18px; }

@media (max-width: 980px){
  .menu{ display:none; }
  .brand{ min-width:unset; }
}
@media (max-width: 560px){
  .actions .pill--navy{ display:none; }
}
</style>
