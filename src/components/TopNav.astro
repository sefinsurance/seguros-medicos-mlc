---
const phoneDisplay = "877-458-2557";
const phoneDial = "+18774582557";
const whatsappLink = "https://wa.me/18774582557";
---
<header class="topbar">
  <div class="mlc-container topbar__inner">
    <a class="brand" href="/">
      <img class="brand__logo" src="/icons/mlc-logo.svg" alt="MLC Insurance" />
      <div class="brand__text">
        <div class="brand__name">MLC Insurance</div>
        <div class="brand__tag">Seguros de salud para tu familia</div>
      </div>
    </a>

    <nav class="menu" aria-label="Primary">
      <a href="/obamacare">Obamacare</a>
      <a href="/medicare">Medicare</a>
      <a href="/vida">Vida</a>
      <a href="/dental-vision">Dental y Visión</a>
    </nav>

    <div class="actions">
      <a class="pill pill--wa" href={whatsappLink} target="_blank" rel="noreferrer">
        <img src="/icons/whatsapp.svg" class="pill__svg" alt="" />
        {phoneDisplay}
      </a>
    </div>
  </div>
</header>

<style>
.topbar{
  background: var(--teal);
  color:#fff;
  box-shadow: 0 10px 30px rgba(9,31,61,0.18);
}
.topbar__inner{
  display:flex;
  align-items:center;
  gap:26px;
  padding:18px 0;
}

.brand{ display:flex; align-items:center; gap:12px; min-width:290px; }
.brand__logo{ width:52px; height:52px; }
.brand__name{ font-weight:900; letter-spacing:-0.2px; font-size:20px; }
.brand__tag{ font-size:13px; opacity:0.85; margin-top:2px; }

.menu{
  display:flex;
  gap:30px;
  align-items:center;
  justify-content:center;
  flex:1;
  font-weight:900;
}
.menu a{ color:#fff; opacity:0.92; padding:10px 6px; }
.menu a:hover{ opacity:1; text-decoration:underline; text-underline-offset:6px; }

.actions{ display:flex; gap:12px; align-items:center; }

.pill{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:12px 18px;
  border-radius:999px;
  font-weight:900;
  white-space:nowrap;
  box-shadow: 0 14px 28px rgba(9,31,61,.20);
}

.pill--wa{
  background: var(--wa); /* SOLID green */
  color:#fff;
}
.pill--wa:hover{ background: var(--wa-deep); }

.pill__svg{
  width:18px; height:18px;
  filter: brightness(0) invert(1);
}

@media (max-width: 980px){
  .menu{ display:none; }
  .brand{ min-width:unset; }
}
</style>
