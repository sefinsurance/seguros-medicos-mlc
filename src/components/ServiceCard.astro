---
const { title, subtitle, icon, href = "#" } = Astro.props;
---
<a class="card" href={href}>
  <div class="card__icon">
    <img src={icon} alt="" />
  </div>
  <div class="card__title">{title}</div>
  <div class="card__sub">{subtitle}</div>
</a>

<style>
.card{
  display:block;
  /* Use the "inner tile" look as the full card */
  background:
    radial-gradient(circle at 30% 20%, rgba(255,255,255,0.98), rgba(220,236,255,0.72));
  border-radius: 26px;
  padding: 26px 22px 20px;
  border: 1px solid rgba(12,34,58,0.10);
  /* stronger border/edge shadow like the reference */
  box-shadow:
    0 18px 45px rgba(9,31,61,0.16),
    0 0 0 1px rgba(255,255,255,0.38) inset,
    0 14px 28px rgba(9,31,61,0.10) inset;
  text-align:center;
  min-height: 185px;
  transition: transform .18s ease, box-shadow .18s ease;
}
.card:hover{
  transform: translateY(-6px);
  box-shadow:
    0 26px 62px rgba(9,31,61,0.20),
    0 0 0 1px rgba(255,255,255,0.42) inset,
    0 16px 32px rgba(9,31,61,0.12) inset;
}
.card__icon{
  width:92px;
  height:92px;
  border-radius: 999px;
  margin: 0 auto 14px;
  display:grid;
  place-items:center;
  /* keep a soft glow behind the icon without creating a second "tile" */
  background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.85), rgba(195,214,255,0.45));
  border: 0;
  box-shadow: none;
}
.card__icon img{ width:74px; height:74px; }
.card__title{ font-weight:900; letter-spacing:-0.2px; }
.card__sub{ margin-top:6px; font-size:13px; color: rgba(35,74,107,0.9); line-height:1.25; }
</style>
