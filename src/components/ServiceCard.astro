---
const { title, subtitle, icon, href = "#" } = Astro.props;
---
<a class="card" href={href}>
  <div class="card__icon">
    <img src={icon} alt="" />
  </div>
  <div class="card__title">{title}</div>
  <div class="card__sub">{subtitle}</div>
</a>

<style>
.card{
  display:block;
  background: rgba(255,255,255,0.92);
  border-radius: 26px;
  padding: 26px 22px 20px;
  border: 1px solid rgba(12,34,58,0.08);
  box-shadow: var(--shadow-tile);
  text-align:center;
  min-height: 185px;
  transition: transform .18s ease, box-shadow .18s ease;
}
.card:hover{
  transform: translateY(-6px);
  box-shadow: 0 30px 70px rgba(9,31,61,0.20);
}
.card__icon{
  width:92px;
  height:92px;
  border-radius: 22px;
  margin: 0 auto 14px;
  display:grid;
  place-items:center;
  background:
    radial-gradient(circle at 30% 20%, rgba(255,255,255,0.98), rgba(220,236,255,0.72));
  border: 1px solid rgba(12,34,58,0.10);
  box-shadow: 0 16px 30px rgba(9,31,61,0.12);
}
.card__icon img{ width:74px; height:74px; }
.card__title{ font-weight:900; letter-spacing:-0.2px; }
.card__sub{ margin-top:6px; font-size:13px; color: rgba(35,74,107,0.9); line-height:1.25; }
</style>
