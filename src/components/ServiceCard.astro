---
const { title, subtitle, icon, href = "#" } = Astro.props;
---
<a class="card" href={href}>
  <div class="card__icon">
    <img src={icon} alt="" />
  </div>
  <div class="card__title">{title}</div>
  <div class="card__sub">{subtitle}</div>
</a>

<style>
.card{
  display:block;
  background: rgba(255,255,255,0.96);
  border-radius: 22px;
  padding: 18px 18px 16px;
  box-shadow: 0 18px 40px rgba(9, 31, 61, 0.18);
  border: 1px solid rgba(18,50,79,0.08);
  transition: transform .18s ease, box-shadow .18s ease;
  text-align:center;
}
.card:hover{
  transform: translateY(-4px);
  box-shadow: 0 26px 64px rgba(9, 31, 61, 0.22);
}
.card__icon{
  width:72px;
  height:72px;
  border-radius: 18px;
  margin: 0 auto 12px;
  display:grid;
  place-items:center;
  background: radial-gradient(circle at 30% 25%, rgba(255,255,255,1), rgba(226,240,255,0.55));
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
  border: 1px solid rgba(18,50,79,0.08);
}
.card__icon img{ width:56px; height:56px; }
.card__title{ font-weight:900; letter-spacing:-.2px; }
.card__sub{ margin-top:6px; font-size:13px; color: var(--muted); line-height:1.2; }
</style>
