---
/**
 * Home icons styled to match the reference screenshot.
 * Usage: <Icon name="aca" /> etc.
 */
const { name = "" } = Astro.props;

const common = {
  width: 88,
  height: 66,
  viewBox: "0 0 176 132",
  xmlns: "http://www.w3.org/2000/svg",
};
---

{name === "aca" && (
  <svg {...common}>
    <defs>
      <radialGradient id="bg" cx="50%" cy="40%" r="70%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
        <stop offset="100%" stop-color="#bcd9ff" stop-opacity="0.65" />
      </radialGradient>
      <linearGradient id="shield" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#3b82f6" />
        <stop offset="100%" stop-color="#1e40af" />
      </linearGradient>
      <linearGradient id="stripe" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#ef4444" />
        <stop offset="100%" stop-color="#b91c1c" />
      </linearGradient>
      <filter id="soft" x="-20%" y="-40%" width="140%" height="200%">
        <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#0b2f55" flood-opacity="0.18" />
      </filter>
    </defs>

    <!-- Oval backdrop -->
    <ellipse cx="88" cy="68" rx="78" ry="52" fill="url(#bg)" filter="url(#soft)" opacity="0.95" />

    <!-- Shield -->
    <path d="M88 22 L128 38 V66 C128 90 105 106 88 112 C71 106 48 90 48 66 V38 L88 22 Z" fill="url(#shield)" />
    <!-- Top band -->
    <path d="M54 41 H122 V55 H54 Z" fill="#1f3b8e" opacity="0.95" />
    <!-- Stars -->
    <g fill="#ffffff" opacity="0.95">
      <path d="M70 48l2.2 4.6 5.1.7-3.7 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.7-3.5 5.1-.7L70 48Z" transform="scale(.35) translate(122,86)" />
      <path d="M70 48l2.2 4.6 5.1.7-3.7 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.7-3.5 5.1-.7L70 48Z" transform="scale(.35) translate(170,86)" />
      <path d="M70 48l2.2 4.6 5.1.7-3.7 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.7-3.5 5.1-.7L70 48Z" transform="scale(.35) translate(218,86)" />
    </g>
    <!-- Stripes -->
    <g>
      <path d="M54 55 H122 V108 C113 113 100 118 88 122 C76 118 63 113 54 108 Z" fill="#ffffff" opacity="0.95" />
      <path d="M60 55 H68 V108" stroke="url(#stripe)" stroke-width="10" />
      <path d="M76 55 H84 V112" stroke="url(#stripe)" stroke-width="10" />
      <path d="M92 55 H100 V112" stroke="url(#stripe)" stroke-width="10" />
      <path d="M108 55 H116 V108" stroke="url(#stripe)" stroke-width="10" />
    </g>
  </svg>
)}

{name === "medicare" && (
  <svg {...common}>
    <defs>
      <radialGradient id="bg2" cx="50%" cy="40%" r="70%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
        <stop offset="100%" stop-color="#c6e7ff" stop-opacity="0.7" />
      </radialGradient>
      <linearGradient id="cad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#34d399" />
        <stop offset="60%" stop-color="#22c55e" />
        <stop offset="100%" stop-color="#0ea5e9" />
      </linearGradient>
      <filter id="soft2" x="-20%" y="-40%" width="140%" height="200%">
        <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#0b2f55" flood-opacity="0.18" />
      </filter>
    </defs>

    <ellipse cx="88" cy="68" rx="78" ry="52" fill="url(#bg2)" filter="url(#soft2)" opacity="0.95" />

    <!-- Simple caduceus -->
    <path d="M88 26c10 10 24 14 24 28 0 12-12 20-24 22-12-2-24-10-24-22 0-14 14-18 24-28Z" fill="url(#cad)" opacity="0.85" />
    <path d="M88 34v64" stroke="#0b4f6c" stroke-width="8" stroke-linecap="round" />
    <path d="M66 60c10-10 18-10 22-6" stroke="#0b4f6c" stroke-width="6" stroke-linecap="round" fill="none" opacity="0.9" />
    <path d="M110 60c-10-10-18-10-22-6" stroke="#0b4f6c" stroke-width="6" stroke-linecap="round" fill="none" opacity="0.9" />
    <path d="M72 84c10 10 18 10 22 6" stroke="#0b4f6c" stroke-width="6" stroke-linecap="round" fill="none" opacity="0.7" />
    <path d="M104 84c-10 10-18 10-22 6" stroke="#0b4f6c" stroke-width="6" stroke-linecap="round" fill="none" opacity="0.7" />
    <circle cx="88" cy="30" r="6" fill="#f59e0b" />
    <path d="M76 42c-10 0-18 6-22 14 10 1 18-1 22-6" fill="#22c55e" opacity="0.9" />
    <path d="M100 42c10 0 18 6 22 14-10 1-18-1-22-6" fill="#0ea5e9" opacity="0.9" />
  </svg>
)}

{name === "life" && (
  <svg {...common}>
    <defs>
      <radialGradient id="bg3" cx="50%" cy="40%" r="70%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
        <stop offset="100%" stop-color="#bcd9ff" stop-opacity="0.65" />
      </radialGradient>
      <linearGradient id="shield2" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#60a5fa" />
        <stop offset="100%" stop-color="#2563eb" />
      </linearGradient>
      <filter id="soft3" x="-20%" y="-40%" width="140%" height="200%">
        <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#0b2f55" flood-opacity="0.18" />
      </filter>
    </defs>

    <ellipse cx="88" cy="68" rx="78" ry="52" fill="url(#bg3)" filter="url(#soft3)" opacity="0.95" />

    <path d="M88 24 L130 40 V68 C130 92 108 108 88 114 C68 108 46 92 46 68 V40 L88 24 Z" fill="url(#shield2)" />
    <path d="M88 42c-10-10-24-2-24 12 0 16 24 30 24 30s24-14 24-30c0-14-14-22-24-12Z" fill="#ffffff" opacity="0.92" />
  </svg>
)}

{name === "dental" && (
  <svg {...common}>
    <defs>
      <radialGradient id="bg4" cx="50%" cy="40%" r="70%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
        <stop offset="100%" stop-color="#c6e7ff" stop-opacity="0.7" />
      </radialGradient>
      <linearGradient id="tooth" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#93c5fd" />
        <stop offset="100%" stop-color="#2563eb" />
      </linearGradient>
      <filter id="soft4" x="-20%" y="-40%" width="140%" height="200%">
        <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#0b2f55" flood-opacity="0.18" />
      </filter>
    </defs>

    <ellipse cx="88" cy="68" rx="78" ry="52" fill="url(#bg4)" filter="url(#soft4)" opacity="0.95" />

    <!-- Tooth -->
    <path d="M72 34c-14 0-26 10-26 24 0 10 4 16 8 22 4 6 6 10 6 20 0 10 6 18 14 18 6 0 10-6 12-14 2-7 3-14 6-14s4 7 6 14c2 8 6 14 12 14 8 0 14-8 14-18 0-10 2-14 6-20 4-6 8-12 8-22 0-14-12-24-26-24-8 0-14 3-20 7-6-4-12-7-20-7Z" fill="url(#tooth)" opacity="0.92" />

    <!-- Eye -->
    <path d="M120 74s-10-14-28-14-28 14-28 14 10 14 28 14 28-14 28-14Z" fill="#ffffff" opacity="0.92" />
    <circle cx="92" cy="74" r="8" fill="#0ea5e9" opacity="0.95" />
    <circle cx="92" cy="74" r="3.5" fill="#0b4f6c" opacity="0.95" />
  </svg>
)}

{!name || !["aca","medicare","life","dental"].includes(name) ? (
  <svg {...common}>
    <rect x="14" y="24" width="148" height="84" rx="42" fill="#dbeafe" />
  </svg>
) : null}
