---
// Static Astro port of ContactBar.jsx. The language toggle now NAVIGATES between
// /en and /es (the site's standard i18n pattern) instead of in-place React state,
// so this section ships zero JS. Visuals/classes match the original exactly.
const { lang = "en" } = Astro.props;
const t = {
  en: { slogan: "Health Insurance for the whole family.", toggle: "ES", other: "/es/" },
  es: { slogan: "Seguro de salud para toda la familia.", toggle: "EN", other: "/en/" },
};
const c = t[lang] || t.en;
---
<header class="bg-[#035582] shadow-sm sticky top-0 z-50">
  <div class="bg-[#035582] text-slate-50 mx-auto px-4 py-3 max-w-6xl flex items-center justify-between flex-wrap gap-2">
    <a href={`/${lang}/`} class="flex items-center gap-3 hover:opacity-80 transition-opacity">
      <img src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69ab1578c293524eeeb25c69/34f395594_logo.png" alt="MLC Insurance" class="w-10 h-10 rounded-full object-cover" width="40" height="40" />
      <div>
        <div class="text-[#ffffff] text-base font-bold leading-tight">MLC Insurance</div>
        <div class="text-slate-50 text-xs">{c.slogan}</div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-white/90">
      <a href="/News/" class="hover:text-white transition-colors">News</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={c.other}
        class="bg-slate-50 text-[#1e3a5f] px-3 py-1 text-xs font-semibold rounded-full border border-[#1e3a5f] hover:bg-[#1e3a5f] hover:text-white transition-colors"
        aria-label={lang === "en" ? "Cambiar a Español" : "Switch to English"}
      >{c.toggle}</a>
      <a href="tel:8774582557" class="flex items-center gap-2 bg-[#22c55e] text-white font-semibold rounded-full px-4 py-2 text-sm hover:bg-[#16a34a] transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        877-458-2557
      </a>
      <a href="https://office.obamacarelocal.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 bg-white/15 hover:bg-white/25 text-white border border-white/30 font-semibold rounded-full px-3 py-2 text-xs transition-colors">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Login
      </a>
    </div>
  </div>
</header>
<script is:inline define:vars={{ lang }}>
  // Keep the cross-page language preference in sync (News islands read this).
  try { localStorage.setItem("mlc_lang", lang); } catch (e) {}
</script>
