---
import { coverage } from '../../data/coverage';

const { lang = 'en', compact = false } = Astro.props;
const isEs = lang === 'es';

const stateNames: Record<string, { en: string; es: string }> = {
  florida: { en: 'Florida', es: 'Florida' },
  texas: { en: 'Texas', es: 'Texas' },
  'north-carolina': { en: 'North Carolina', es: 'Carolina del Norte' },
  'south-carolina': { en: 'South Carolina', es: 'Carolina del Sur' },
  georgia: { en: 'Georgia', es: 'Georgia' },
  arizona: { en: 'Arizona', es: 'Arizona' },
  tennessee: { en: 'Tennessee', es: 'Tennessee' },
  ohio: { en: 'Ohio', es: 'Ohio' },
  indiana: { en: 'Indiana', es: 'Indiana' },
  michigan: { en: 'Michigan', es: 'Michigan' },
  missouri: { en: 'Missouri', es: 'Misuri' },
  mississippi: { en: 'Mississippi', es: 'Misisipi' },
  alabama: { en: 'Alabama', es: 'Alabama' },
};

const countyFix: Record<string, string> = {
  'miami-dade': 'Miami-Dade',
  'st-louis': 'St. Louis',
  'st-charles': 'St. Charles',
  'el-paso': 'El Paso',
  'fort-bend': 'Fort Bend',
  'palm-beach': 'Palm Beach',
};

function titleCaseSlug(slug: string) {
  if (countyFix[slug]) return countyFix[slug];
  return slug
    .split('-')
    .map((s) => (s ? s[0].toUpperCase() + s.slice(1) : s))
    .join(' ');
}

const states = Object.keys(coverage);
---

<section class={compact ? 'areas areas-compact' : 'areas'}>
  {!compact ? (
    <div class="head">
      <h2>{isEs ? 'Áreas que atendemos' : 'Areas we serve'}</h2>
      <p class="muted">
        {isEs
          ? 'Organizado por estado para que encuentres tu condado rápido. Si no ves tu condado, igual podemos ayudarte.'
          : "Organized by state so you can find your county fast. If you don't see your county, we can still help."}
      </p>
    </div>
  ) : (
    <div class="head" style="margin-bottom:8px">
      <h3 style="margin:0">{isEs ? 'Condados que atendemos' : 'Counties we serve'}</h3>
    </div>
  )}

  <div class="states">
    {states.map((st) => {
      const label = stateNames[st] ? (isEs ? stateNames[st].es : stateNames[st].en) : titleCaseSlug(st);
      const counties = coverage[st] || [];
      return (
        <details class="state">
          <summary>
            <span class="stateTitle">{label}</span>
            <span class="stateMeta">{counties.length} {isEs ? 'condados' : 'counties'}</span>
          </summary>

          <div class="countyGrid">
            {counties.map((c) => (
              <a class="county" href={`/${lang}/${st}/${c}/`}>
                {isEs ? `Condado ${titleCaseSlug(c)}` : `${titleCaseSlug(c)} County`}
              </a>
            ))}
          </div>

          <div class="stateCta">
            <a class="btn btn--soft" href={`/${lang}/${st}/`}>
              {isEs ? `Ver ${label}` : `View ${label}`}
            </a>
          </div>
        </details>
      );
    })}
  </div>
</section>

<style>
.areas{margin:28px 0 0}
.head{margin-bottom:14px}
.states{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
.state{
  border:1px solid rgba(15,23,42,.10);
  background:rgba(255,255,255,.9);
  border-radius:16px;
  padding:12px 14px;
  box-shadow:0 10px 30px rgba(2,6,23,.06);
}
.state summary{cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:10px}
.state summary::-webkit-details-marker{display:none}
.stateTitle{font-weight:900}
.stateMeta{color:var(--muted);font-size:14px}
.countyGrid{display:flex;flex-wrap:wrap;gap:10px;margin-top:12px}
.county{
  display:inline-flex;align-items:center;justify-content:center;
  padding:8px 10px;border-radius:999px;
  border:1px solid rgba(15,23,42,.10);
  background:linear-gradient(180deg, rgba(255,255,255,.95), rgba(247,250,252,.95));
  font-weight:800;font-size:14px;
}
.county:hover{border-color:rgba(15,23,42,.22);transform:translateY(-1px)}
.stateCta{margin-top:12px}
.areas-compact .states{grid-template-columns:1fr}
@media (max-width:860px){
  .states{grid-template-columns:1fr}
}
</style>
